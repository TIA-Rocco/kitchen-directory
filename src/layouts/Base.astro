---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import { safeJsonLd } from '../lib/jsonld';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /**
   * Emit <meta name="robots" content="noindex, nofollow"> to keep this page out
   * of search-engine and AI indexes while it remains reachable by direct URL.
   * Used to temporarily hide the blog pending content-team review.
   */
  noindex?: boolean;
  /**
   * Responsive preload for the LCP hero image (AVIF). Pages with a full-bleed
   * hero (homepage, service categories) pass the AVIF srcset so the browser
   * starts fetching the LCP image during head parse instead of after layout —
   * the decisive win for mobile LCP. Built via heroImage.ts so it matches the
   * <picture> in HeroImage.astro exactly.
   */
  heroPreload?: { srcset: string; sizes?: string };
}

const { title, description, ogImage, canonicalUrl, jsonLd, noindex, heroPreload } = Astro.props;
const canonical = canonicalUrl || Astro.url.href;
const siteName = 'Kitchen Equipment Canada';
const resolvedOgImage = new URL(ogImage ?? '/og-image.png', canonical).href;
const ogImageAlt = `${siteName}: ${title}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:secure_url" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- Google Search Console verification -->
    <meta name="google-site-verification" content="p7b7atrYTNaA0HXIVyCdrXgHeS6ldTDlJ0TtdaKbQDA" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Structured Data -->
    {jsonLd && (
      Array.isArray(jsonLd)
        ? jsonLd.map((schema) => (
            <script type="application/ld+json" set:html={safeJsonLd(schema)} />
          ))
        : <script type="application/ld+json" set:html={safeJsonLd(jsonLd)} />
    )}

    {heroPreload && (
      <link
        rel="preload"
        as="image"
        type="image/avif"
        imagesrcset={heroPreload.srcset}
        imagesizes={heroPreload.sizes ?? '100vw'}
        fetchpriority="high"
      />
    )}
    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-LR39F9SB25"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-LR39F9SB25');
    </script>
  </head>
  <body class="min-h-screen bg-white text-neutral-900 antialiased">
    <div class="isolate">
      <slot />
    </div>
    <Analytics />
  </body>
</html>
