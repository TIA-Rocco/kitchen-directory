---
import '../styles/global.css';

interface Props {
  title: string;
  activeNav?: 'dashboard' | 'submissions' | 'reviews' | 'companies';
}

const { title, activeNav = 'dashboard' } = Astro.props;
const userEmail = Astro.locals.user?.email ?? '';

const navItems = [
  { key: 'dashboard', href: '/admin', label: 'Dashboard' },
  { key: 'submissions', href: '/admin/submissions', label: 'Submissions' },
  { key: 'reviews', href: '/admin/reviews', label: 'Reviews' },
  { key: 'companies', href: '/admin/companies', label: 'Companies' },
] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} | Admin · Kitchen Equipment Canada</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-neutral-50 text-neutral-900 antialiased">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="hidden w-60 shrink-0 border-r border-neutral-200 bg-white md:flex md:flex-col">
        <div class="px-5 py-5 border-b border-neutral-200">
          <a href="/admin" class="block">
            <div class="text-sm font-semibold text-neutral-900">Kitchen Equipment</div>
            <div class="text-xs text-neutral-500">Admin</div>
          </a>
        </div>
        <nav class="flex-1 px-3 py-4 space-y-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                'block rounded-md px-3 py-2 text-sm font-medium transition-colors',
                activeNav === item.key
                  ? 'bg-emerald-50 text-emerald-700'
                  : 'text-neutral-700 hover:bg-neutral-100',
              ]}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <div class="px-3 py-4 border-t border-neutral-200">
          <button
            type="button"
            data-signout
            class="w-full rounded-md px-3 py-2 text-left text-sm text-neutral-600 hover:bg-neutral-100"
          >
            Sign out
          </button>
        </div>
      </aside>

      <!-- Main -->
      <div class="flex flex-1 flex-col min-w-0">
        <header class="flex items-center justify-between border-b border-neutral-200 bg-white px-6 py-3">
          <h1 class="text-base font-semibold text-neutral-900">{title}</h1>
          <div class="flex items-center gap-3">
            <span class="hidden text-xs text-neutral-500 sm:inline">{userEmail}</span>
            <button
              type="button"
              data-signout
              class="rounded-md border border-neutral-200 px-3 py-1.5 text-xs font-medium text-neutral-700 hover:bg-neutral-50"
            >
              Sign out
            </button>
          </div>
        </header>
        <main class="flex-1 px-6 py-6">
          <slot />
        </main>
      </div>
    </div>

    <!-- Toast container -->
    <div
      id="toast"
      class="pointer-events-none fixed bottom-6 right-6 z-50 hidden rounded-md bg-neutral-900 px-4 py-2.5 text-sm text-white shadow-lg"
    ></div>

    <script>
      import { createBrowserClient } from '@supabase/ssr';

      const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
      const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

      // Sign-out: clear session via Supabase JS (cookie-based via @supabase/ssr browser client)
      document.querySelectorAll('[data-signout]').forEach((el) => {
        el.addEventListener('click', async (e) => {
          e.preventDefault();
          const supabase = createBrowserClient(supabaseUrl, supabaseAnonKey);
          await supabase.auth.signOut();
          window.location.href = '/admin/login';
        });
      });

      // Global toast helper
      (window as any).showToast = (msg: string, type: 'success' | 'error' = 'success') => {
        const el = document.getElementById('toast');
        if (!el) return;
        el.textContent = msg;
        el.classList.remove('hidden', 'bg-neutral-900', 'bg-red-600');
        el.classList.add(type === 'error' ? 'bg-red-600' : 'bg-neutral-900');
        clearTimeout((window as any).__toastTimer);
        (window as any).__toastTimer = setTimeout(() => el.classList.add('hidden'), 3500);
      };
    </script>
  </body>
</html>
