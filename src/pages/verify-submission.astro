---
export const prerender = false;

import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const status = Astro.url.searchParams.get('status');
const ok = status === 'ok';
---

<Base
  title={ok ? 'Submission Verified' : 'Verification Issue'}
  description="Verify your supplier submission to Kitchen Equipment Canada."
>
  <Header />

  <main class="flex min-h-[60vh] items-center justify-center px-6 py-16">
    <div class="max-w-lg text-center">
      {ok ? (
        <>
          <div class="mx-auto flex size-12 items-center justify-center rounded-full bg-emerald-100">
            <svg class="size-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <h1 class="mt-4 text-3xl font-semibold tracking-tight">Email verified</h1>
          <p class="mt-3 text-neutral-600">
            Thanks — your application is now in the editorial review queue. Check your inbox for receipt confirmation. We'll be in touch as soon as possible.
          </p>
          <a href="/" class="mt-8 inline-flex rounded-md bg-emerald-600 px-3 py-2 text-sm font-medium text-white hover:bg-emerald-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600">
            Back to directory
          </a>
        </>
      ) : (
        <>
          <div class="mx-auto flex size-12 items-center justify-center rounded-full bg-amber-100">
            <svg class="size-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
          </div>
          <h1 class="mt-4 text-3xl font-semibold tracking-tight">Verification link invalid</h1>
          <p class="mt-3 text-neutral-600">
            This verification link is invalid or expired. Please submit your application again.
          </p>
          <a href="/list-your-company" class="mt-8 inline-flex rounded-md bg-emerald-600 px-3 py-2 text-sm font-medium text-white hover:bg-emerald-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600">
            Apply again
          </a>
        </>
      )}
    </div>
  </main>

  <Footer />
</Base>
