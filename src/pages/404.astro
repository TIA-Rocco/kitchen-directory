---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
>
  <header class="border-b border-neutral-950/5 bg-white">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
      <a href="/" aria-label="Homepage" class="flex items-center gap-2">
        <img src="https://assets.ui.sh/marks/1.svg?color=emerald-600&text=KE&textColor=neutral-900&font=inter" alt="Kitchen Equipment Canada" class="h-8" />
        <span class="text-lg font-semibold tracking-tight">KitchenEquipment.ca</span>
      </a>
    </nav>
  </header>

  <main class="flex min-h-[60vh] items-center justify-center px-6">
    <div class="text-center">
      <p class="text-sm font-medium text-emerald-600">404</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight">Page not found</h1>
      <p class="mt-2 text-neutral-500">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="mt-6 inline-flex rounded-md bg-emerald-600 px-3 py-2 text-sm font-medium text-white hover:bg-emerald-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600">
        Back to directory
      </a>
    </div>
  </main>
</Base>
