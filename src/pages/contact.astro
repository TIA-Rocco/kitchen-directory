---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contact Us"
  description="Get in touch with Kitchen Equipment Canada. General inquiries, company profile updates, and partnership opportunities."
>
  <header class="border-b border-neutral-950/5 bg-white">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
      <a href="/" aria-label="Homepage" class="flex items-center gap-2">
        <img src="https://assets.ui.sh/marks/1.svg?color=emerald-600&text=KE&textColor=neutral-900&font=inter" alt="Kitchen Equipment Canada" class="h-8" />
        <span class="text-lg font-semibold tracking-tight">KitchenEquipment.ca</span>
      </a>
      <a href="/submit-review" class="text-sm font-medium text-neutral-600 hover:text-neutral-900">Submit a Review</a>
    </nav>
  </header>

  <main class="py-16">
    <div class="mx-auto max-w-xl px-6">
      <a href="/" class="text-sm text-neutral-500 hover:text-neutral-700">&larr; Back to directory</a>

      <h1 class="mt-6 text-3xl font-semibold tracking-tight">Contact Us</h1>
      <p class="mt-2 text-neutral-500">Have a question or want to update your company profile? We'd love to hear from you.</p>

      <form action="/api/contact" method="POST" class="mt-10 space-y-6">
        <!-- Honeypot -->
        <div class="hidden" aria-hidden="true">
          <label for="fax">Fax</label>
          <input type="text" id="fax" name="fax" tabindex="-1" autocomplete="off" />
        </div>

        <div>
          <label for="reason" class="text-sm font-medium text-neutral-900">Reason for Contact</label>
          <div class="mt-1.5 inline-grid w-full grid-cols-[1fr_--spacing(8)]">
            <select id="reason" name="type" required class="col-span-full row-start-1 w-full appearance-none rounded-lg py-2.5 pr-8 pl-3 text-sm ring-1 ring-black/10 focus:outline-2 focus:-outline-offset-1 focus:outline-emerald-600">
              <option value="general">General Inquiry</option>
              <option value="update_profile">Update My Company Profile</option>
            </select>
            <svg viewBox="0 0 8 5" width="8" height="5" fill="none" class="pointer-events-none col-start-2 row-start-1 place-self-center">
              <path d="M.5.5 4 4 7.5.5" stroke="currentcolor" />
            </svg>
          </div>
        </div>

        <div>
          <label for="contact_name" class="text-sm font-medium text-neutral-900">Your Name</label>
          <input type="text" id="contact_name" name="name" required class="mt-1.5 w-full rounded-lg px-3 py-2.5 text-sm ring-1 ring-black/10 focus:outline-2 focus:-outline-offset-1 focus:outline-emerald-600 max-sm:text-base/6" />
        </div>

        <div>
          <label for="contact_email" class="text-sm font-medium text-neutral-900">Email Address</label>
          <input type="email" id="contact_email" name="email" required class="mt-1.5 w-full rounded-lg px-3 py-2.5 text-sm ring-1 ring-black/10 focus:outline-2 focus:-outline-offset-1 focus:outline-emerald-600 max-sm:text-base/6" />
        </div>

        <div>
          <label for="company_name" class="text-sm font-medium text-neutral-900">Company Name <span class="font-normal text-neutral-400">(for profile updates)</span></label>
          <input type="text" id="company_name" name="company_name" class="mt-1.5 w-full rounded-lg px-3 py-2.5 text-sm ring-1 ring-black/10 focus:outline-2 focus:-outline-offset-1 focus:outline-emerald-600 max-sm:text-base/6" />
        </div>

        <div>
          <label for="message" class="text-sm font-medium text-neutral-900">Message</label>
          <textarea id="message" name="message" required rows="5" class="mt-1.5 w-full rounded-lg px-3 py-2.5 text-sm ring-1 ring-black/10 focus:outline-2 focus:-outline-offset-1 focus:outline-emerald-600 max-sm:text-base/6" placeholder="How can we help?"></textarea>
        </div>

        <button type="submit" class="w-full rounded-md bg-emerald-600 px-3 py-2.5 text-sm font-medium text-white hover:bg-emerald-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600">
          Send Message
        </button>
      </form>

      <div class="mt-12 rounded-xl bg-neutral-50 p-6">
        <h2 class="text-sm font-semibold text-neutral-900">Direct Contact</h2>
        <p class="mt-2 text-sm text-neutral-600">
          Email us directly at <a href="mailto:info@kitchenequipment.ca" class="font-medium text-emerald-600 hover:text-emerald-500">info@kitchenequipment.ca</a>
        </p>
      </div>
    </div>
  </main>

  <footer class="border-t border-neutral-950/5 py-10">
    <div class="mx-auto max-w-7xl px-6 text-center text-sm text-neutral-500">
      <p>kitchenequipment.ca. Independent commercial kitchen equipment supplier directory.</p>
    </div>
  </footer>
</Base>
