---
export const prerender = false;

import Admin from '../../../layouts/Admin.astro';
import { supabaseAdmin } from '../../../lib/supabase-server';

const { id } = Astro.params;

const { data: review, error } = await supabaseAdmin
  .from('reviews')
  .select('*, companies(name, slug)')
  .eq('id', id)
  .maybeSingle();

if (error || !review) {
  return new Response('Not found', { status: 404 });
}

function fmt(ts: string | null) {
  return ts ? new Date(ts).toLocaleString('en-CA', { dateStyle: 'medium', timeStyle: 'short' }) : '—';
}

function stars(rating: number) {
  const r = Math.max(0, Math.min(5, rating));
  return '★'.repeat(r) + '☆'.repeat(5 - r);
}

const company = (review as any).companies as { name: string; slug: string } | null;
const isPending = review.status === 'pending';

const statusStyles: Record<string, string> = {
  pending: 'bg-amber-50 text-amber-800 ring-amber-200',
  approved: 'bg-emerald-50 text-emerald-800 ring-emerald-200',
  rejected: 'bg-red-50 text-red-700 ring-red-200',
};
---

<Admin title={`Review by ${review.reviewer_name}`} activeNav="reviews">
  <div class="mb-4 flex items-center gap-3">
    <a href="/admin/reviews" class="text-sm text-emerald-700 hover:text-emerald-800">
      ← All reviews
    </a>
    <span class:list={['inline-flex rounded-full px-2 py-0.5 text-xs font-medium ring-1', statusStyles[review.status] ?? 'bg-neutral-100 text-neutral-700 ring-neutral-200']}>
      {review.status}
    </span>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    <!-- Main column -->
    <div class="space-y-6 lg:col-span-2">
      <!-- Review content -->
      <section class="rounded-xl bg-white p-6 ring-1 ring-black/5">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-sm font-semibold text-neutral-900">Review</h2>
            <div class="mt-1 text-2xl font-mono text-amber-500">{stars(review.rating)}<span class="ml-2 align-middle text-sm text-neutral-500">{review.rating}/5</span></div>
          </div>
          <div class="text-right">
            <div class="text-xs uppercase tracking-wide text-neutral-500">Company</div>
            <dd class="mt-0.5 text-sm font-medium text-neutral-900">
              {company ? (
                <a href={`/companies/${company.slug}`} target="_blank" rel="noopener" class="text-emerald-700 hover:underline">
                  {company.name}
                </a>
              ) : '—'}
            </dd>
          </div>
        </div>

        <div class="mt-5">
          <div class="text-xs uppercase tracking-wide text-neutral-500">Service</div>
          <div class="mt-1 text-sm text-neutral-800">{review.custom_service || review.service_category}</div>
        </div>

        <div class="mt-5">
          <div class="text-xs uppercase tracking-wide text-neutral-500">Review text</div>
          <p class="mt-1 whitespace-pre-line text-sm text-neutral-800">{review.review_text}</p>
        </div>
      </section>

      <!-- Internal notes -->
      <section class="rounded-xl bg-white p-6 ring-1 ring-black/5">
        <div class="flex items-center justify-between">
          <h2 class="text-sm font-semibold text-neutral-900">Internal notes</h2>
          <span data-notes-status class="text-xs text-neutral-500"></span>
        </div>
        <textarea
          data-notes
          data-review-id={review.id}
          rows="5"
          placeholder="Notes for the team. Auto-saves on blur. Rejection reasons are appended here automatically."
          class="mt-3 w-full rounded-lg px-3 py-2.5 text-sm ring-1 ring-black/10 focus:outline-2 focus:-outline-offset-1 focus:outline-emerald-600"
        >{review.internal_notes ?? ''}</textarea>
      </section>
    </div>

    <!-- Sidebar -->
    <aside class="space-y-6">
      <section class="rounded-xl bg-white p-6 ring-1 ring-black/5">
        <h2 class="text-sm font-semibold text-neutral-900">Reviewer</h2>
        <dl class="mt-3 space-y-2 text-sm">
          <div>
            <dt class="text-xs uppercase tracking-wide text-neutral-500">Name</dt>
            <dd class="mt-0.5 text-neutral-900">{review.reviewer_name}</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-wide text-neutral-500">Submitted</dt>
            <dd class="mt-0.5 text-neutral-900">{fmt(review.created_at)}</dd>
          </div>
          {review.approved_at && (
            <div>
              <dt class="text-xs uppercase tracking-wide text-neutral-500">Approved</dt>
              <dd class="mt-0.5 text-neutral-900">{fmt(review.approved_at)}</dd>
            </div>
          )}
          {review.rejected_at && (
            <div>
              <dt class="text-xs uppercase tracking-wide text-neutral-500">Rejected</dt>
              <dd class="mt-0.5 text-neutral-900">{fmt(review.rejected_at)}</dd>
            </div>
          )}
        </dl>
      </section>

      <!-- Sticky action bar -->
      <section class="sticky top-6 rounded-xl bg-white p-6 ring-1 ring-black/5">
        <h2 class="text-sm font-semibold text-neutral-900">Actions</h2>
        <div class="mt-4 space-y-2" data-actions data-review-id={review.id}>
          <button
            type="button"
            data-action="approve"
            disabled={!isPending}
            class="w-full rounded-md bg-emerald-600 px-3 py-2.5 text-sm font-medium text-white hover:bg-emerald-500 disabled:cursor-not-allowed disabled:opacity-40"
          >
            Approve
          </button>
          <button
            type="button"
            data-action="reject"
            disabled={!isPending}
            class="w-full rounded-md border border-neutral-300 bg-white px-3 py-2.5 text-sm font-medium text-neutral-700 hover:bg-neutral-50 disabled:cursor-not-allowed disabled:opacity-40"
          >
            Reject
          </button>
          {review.status === 'rejected' && (
            <button
              type="button"
              data-action="reopen"
              class="w-full rounded-md border border-neutral-300 bg-white px-3 py-2.5 text-sm font-medium text-neutral-700 hover:bg-neutral-50"
            >
              Reopen to pending
            </button>
          )}

          <!-- Remove (permanent hard delete) — available for any status; the
               primary way to take an already-approved review off the live site. -->
          <div class="mt-2 border-t border-neutral-100 pt-3">
            <button
              type="button"
              data-action="delete"
              class="w-full rounded-md border border-red-200 bg-white px-3 py-2.5 text-sm font-medium text-red-600 hover:bg-red-50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600"
            >
              Remove review
            </button>
            <p class="mt-2 text-xs text-neutral-500">
              Permanently deletes this review. This can't be undone.{review.status === 'approved' ? ' The site rebuilds to drop it.' : ''}
            </p>
          </div>
        </div>
        {review.status === 'approved' && (
          <p class="mt-3 text-xs text-neutral-500">
            Approved and live on the company profile after the next rebuild.
          </p>
        )}
      </section>
    </aside>
  </div>

  <script>
    // Auto-save internal notes (debounced 1s, also on blur)
    const notesEl = document.querySelector<HTMLTextAreaElement>('[data-notes]');
    const statusEl = document.querySelector<HTMLElement>('[data-notes-status]');
    if (notesEl) {
      const id = notesEl.getAttribute('data-review-id');
      let timer: number | undefined;
      const save = async () => {
        if (statusEl) statusEl.textContent = 'Saving…';
        try {
          const res = await fetch(`/api/admin/reviews/${id}/notes`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ internal_notes: notesEl.value }),
          });
          if (statusEl) statusEl.textContent = res.ok ? 'Saved' : 'Save failed';
        } catch {
          if (statusEl) statusEl.textContent = 'Save failed';
        }
      };
      notesEl.addEventListener('input', () => {
        if (statusEl) statusEl.textContent = 'Typing…';
        window.clearTimeout(timer);
        timer = window.setTimeout(save, 1000);
      });
      notesEl.addEventListener('blur', () => {
        window.clearTimeout(timer);
        save();
      });
    }

    // Action buttons
    const actions = document.querySelector<HTMLElement>('[data-actions]');
    if (actions) {
      const id = actions.getAttribute('data-review-id')!;
      const toast = (msg: string, type: 'success' | 'error' = 'success') =>
        (window as any).showToast?.(msg, type);
      const disable = () => {
        actions.querySelectorAll('button').forEach((b) => ((b as HTMLButtonElement).disabled = true));
      };

      actions.querySelectorAll<HTMLButtonElement>('button[data-action]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const action = btn.getAttribute('data-action')!;

          // Capture a reason for reject — saved to internal notes (audit trail).
          let reason = '';
          if (action === 'reject') {
            if (!confirm('Reject this review?')) return;
            reason = prompt('Reason for rejection (saved to internal notes, optional):')?.trim() ?? '';
          } else if (action === 'reopen') {
            if (!confirm('Reopen this review to pending?')) return;
          } else if (action === 'delete') {
            if (!confirm('Permanently remove this review? This cannot be undone.')) return;
          }

          btn.disabled = true;
          try {
            const res = await fetch(`/api/admin/reviews/${id}/${action}`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(reason ? { notes: reason } : {}),
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) {
              toast(data?.error || 'Action failed', 'error');
              btn.disabled = false;
              return;
            }

            if (action === 'approve') {
              disable();
              toast('Approved. Live after the next rebuild.');
              setTimeout(() => (window.location.href = '/admin/reviews'), 1400);
            } else if (action === 'reject') {
              disable();
              toast('Rejected.');
              setTimeout(() => (window.location.href = '/admin/reviews'), 1200);
            } else if (action === 'reopen') {
              toast('Reopened to pending.');
              setTimeout(() => window.location.reload(), 800);
            } else if (action === 'delete') {
              disable();
              toast('Review removed.');
              setTimeout(() => (window.location.href = '/admin/reviews'), 1200);
            }
          } catch (err) {
            console.error(err);
            toast('Network error', 'error');
            btn.disabled = false;
          }
        });
      });
    }
  </script>
</Admin>
