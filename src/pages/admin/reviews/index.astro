---
export const prerender = false;

import Admin from '../../../layouts/Admin.astro';
import { supabaseAdmin } from '../../../lib/supabase-server';

// Filter tabs. Reviews have no `unverified`/`needs_info` states (no email
// gate), so the queue is simply pending -> approved/rejected.
const FILTERS: Record<string, string[]> = {
  pending: ['pending'],
  approved: ['approved'],
  rejected: ['rejected'],
  all: ['pending', 'approved', 'rejected'],
};
const requested = Astro.url.searchParams.get('status') ?? 'pending';
const activeFilter = FILTERS[requested] ? requested : 'pending';

const { data: reviews } = await supabaseAdmin
  .from('reviews')
  .select('id, reviewer_name, rating, review_text, service_category, custom_service, status, created_at, companies(name, slug)')
  .in('status', FILTERS[activeFilter])
  .order('created_at', { ascending: false });

function fmt(ts: string) {
  return new Date(ts).toLocaleDateString('en-CA', { dateStyle: 'medium' });
}

function preview(text: string | null, n = 80) {
  if (!text) return '—';
  return text.length > n ? text.slice(0, n).trimEnd() + '…' : text;
}

function stars(rating: number) {
  const r = Math.max(0, Math.min(5, rating));
  return '★'.repeat(r) + '☆'.repeat(5 - r);
}

const statusStyles: Record<string, string> = {
  pending: 'bg-amber-50 text-amber-800 ring-amber-200',
  approved: 'bg-emerald-50 text-emerald-800 ring-emerald-200',
  rejected: 'bg-red-50 text-red-700 ring-red-200',
};

const TABS: { key: string; label: string }[] = [
  { key: 'pending', label: 'Pending' },
  { key: 'approved', label: 'Approved' },
  { key: 'rejected', label: 'Rejected' },
  { key: 'all', label: 'All' },
];
---

<Admin title="Reviews" activeNav="reviews">
  <div class="rounded-xl bg-white ring-1 ring-black/5">
    <div class="flex flex-wrap items-center gap-1 border-b border-neutral-200 px-3 py-2">
      {TABS.map((t) => (
        <a
          href={`/admin/reviews?status=${t.key}`}
          class:list={[
            'rounded-md px-3 py-1.5 text-xs font-medium',
            t.key === activeFilter
              ? 'bg-neutral-900 text-white'
              : 'text-neutral-600 hover:bg-neutral-100',
          ]}
        >
          {t.label}
        </a>
      ))}
    </div>
    <div class="border-b border-neutral-200 px-5 py-3">
      <h2 class="text-sm font-semibold text-neutral-900">
        {TABS.find((t) => t.key === activeFilter)?.label} ({reviews?.length ?? 0})
      </h2>
    </div>
    {!reviews || reviews.length === 0 ? (
      <div class="px-5 py-12 text-center text-sm text-neutral-500">Nothing here.</div>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-neutral-50 text-left text-xs uppercase tracking-wide text-neutral-500">
            <tr>
              <th class="px-5 py-2.5 font-medium">Submitted</th>
              <th class="px-5 py-2.5 font-medium">Company</th>
              <th class="px-5 py-2.5 font-medium">Reviewer</th>
              <th class="px-5 py-2.5 font-medium">Rating</th>
              <th class="px-5 py-2.5 font-medium">Preview</th>
              <th class="px-5 py-2.5 font-medium">Status</th>
              <th class="px-5 py-2.5"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            {reviews.map((r) => (
              <tr class="align-top hover:bg-neutral-50">
                <td class="px-5 py-3 text-neutral-600">{fmt(r.created_at)}</td>
                <td class="px-5 py-3 font-medium text-neutral-900">
                  {(r as any).companies?.name ?? '—'}
                </td>
                <td class="px-5 py-3 text-neutral-700">{r.reviewer_name}</td>
                <td class="px-5 py-3 font-mono text-xs text-amber-600">{stars(r.rating)}</td>
                <td class="px-5 py-3 max-w-md text-neutral-600">
                  <div>{preview(r.review_text)}</div>
                  <div class="mt-0.5 text-xs text-neutral-500">
                    {r.custom_service || r.service_category}
                  </div>
                </td>
                <td class="px-5 py-3">
                  <span class:list={['inline-flex rounded-full px-2 py-0.5 text-xs font-medium ring-1', statusStyles[r.status] ?? 'bg-neutral-100 text-neutral-700 ring-neutral-200']}>
                    {r.status}
                  </span>
                </td>
                <td class="px-5 py-3 text-right">
                  <a
                    href={`/admin/reviews/${r.id}`}
                    class="rounded-md border border-neutral-200 px-3 py-1.5 text-xs font-medium text-neutral-700 hover:bg-neutral-50"
                  >
                    View
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</Admin>
