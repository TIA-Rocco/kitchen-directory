---
export const prerender = false;

import Admin from '../../../layouts/Admin.astro';
import { supabaseAdmin } from '../../../lib/supabase-server';

const { slug } = Astro.params;
const { data: company, error } = await supabaseAdmin
  .from('companies')
  .select('slug, name, ranking_score, ranking_breakdown, is_featured')
  .eq('slug', slug)
  .maybeSingle();

if (error || !company) {
  return new Response('Not found', { status: 404 });
}

// Criteria + weights (must mirror DB trigger formula). Order matters for display.
const CRITERIA = [
  { key: 'service_range', label: 'Service Range', weight: 0.2 },
  { key: 'customer_reviews', label: 'Customer Reviews', weight: 0.25 },
  { key: 'industry_experience', label: 'Industry Experience', weight: 0.2 },
  { key: 'response_time', label: 'Response Time', weight: 0.15 },
  { key: 'pricing_transparency', label: 'Pricing Transparency', weight: 0.1 },
  { key: 'certifications', label: 'Certifications', weight: 0.1 },
] as const;

const breakdown = (company.ranking_breakdown ?? {}) as Record<string, number>;
---

<Admin title={`Edit · ${company.name}`} activeNav="companies">
  <div class="mb-4">
    <a href="/admin/companies" class="text-sm text-emerald-700 hover:text-emerald-800">← All companies</a>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    <section class="lg:col-span-2 rounded-xl bg-white p-6 ring-1 ring-black/5">
      <h2 class="text-sm font-semibold text-neutral-900">Ranking breakdown</h2>
      <p class="mt-1 text-xs text-neutral-500">
        Score each criterion 0–10. The composite score is a weighted average and recomputes
        automatically on save.
      </p>

      <form id="ranking-form" class="mt-5 space-y-4" data-slug={company.slug}>
        {CRITERIA.map((c) => (
          <div class="flex items-center gap-4">
            <label for={`r_${c.key}`} class="w-56 text-sm text-neutral-800">
              {c.label}
              <span class="ml-1 text-xs text-neutral-500">({Math.round(c.weight * 100)}%)</span>
            </label>
            <input
              id={`r_${c.key}`}
              name={c.key}
              data-criterion={c.key}
              data-weight={c.weight}
              type="number"
              min="0"
              max="10"
              step="0.1"
              required
              value={typeof breakdown[c.key] === 'number' ? breakdown[c.key] : 0}
              class="w-32 rounded-lg px-3 py-2 text-sm ring-1 ring-black/10 focus:outline-2 focus:-outline-offset-1 focus:outline-emerald-600"
            />
          </div>
        ))}

        <div class="mt-6 flex items-center justify-between border-t border-neutral-200 pt-4">
          <button
            type="submit"
            class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-500"
          >
            Save
          </button>
          <div class="text-sm text-neutral-600">
            Live preview:
            <span id="preview-score" class="ml-1 font-semibold text-neutral-900">—</span>
            <span class="ml-2 text-xs text-neutral-500">/ 10</span>
          </div>
        </div>
      </form>
    </section>

    <aside class="rounded-xl bg-white p-6 ring-1 ring-black/5">
      <h2 class="text-sm font-semibold text-neutral-900">Current</h2>
      <dl class="mt-3 space-y-2 text-sm">
        <div>
          <dt class="text-xs uppercase tracking-wide text-neutral-500">Saved score</dt>
          <dd class="mt-0.5 text-2xl font-semibold text-neutral-900">
            {typeof company.ranking_score === 'number' ? company.ranking_score.toFixed(1) : '—'}
          </dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-wide text-neutral-500">Slug</dt>
          <dd class="mt-0.5 font-mono text-xs text-neutral-700">{company.slug}</dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-wide text-neutral-500">Featured</dt>
          <dd class="mt-0.5">{company.is_featured ? 'Yes' : 'No'}</dd>
        </div>
      </dl>
      <a
        href={`/companies/${company.slug}`}
        target="_blank"
        rel="noopener"
        class="mt-4 inline-flex text-xs text-emerald-700 hover:text-emerald-800"
      >
        View public profile →
      </a>
    </aside>
  </div>

  <script>
    const form = document.getElementById('ranking-form') as HTMLFormElement | null;
    const preview = document.getElementById('preview-score');
    if (form && preview) {
      const slug = form.getAttribute('data-slug')!;
      const inputs = Array.from(form.querySelectorAll<HTMLInputElement>('input[data-criterion]'));

      const recompute = () => {
        let total = 0;
        let weightSum = 0;
        for (const i of inputs) {
          const v = parseFloat(i.value);
          const w = parseFloat(i.getAttribute('data-weight') || '0');
          if (Number.isFinite(v) && Number.isFinite(w)) {
            total += v * w;
            weightSum += w;
          }
        }
        const score = weightSum > 0 ? total / weightSum : 0;
        (preview as HTMLElement).textContent = score.toFixed(2);
      };
      inputs.forEach((i) => i.addEventListener('input', recompute));
      recompute();

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const payload: Record<string, number> = {};
        for (const i of inputs) {
          const v = parseFloat(i.value);
          if (!Number.isFinite(v) || v < 0 || v > 10) {
            (window as any).showToast?.(`${i.name} must be 0–10`, 'error');
            return;
          }
          payload[i.getAttribute('data-criterion')!] = v;
        }
        const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        if (btn) btn.disabled = true;
        try {
          const res = await fetch(`/api/admin/companies/${slug}/ranking`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) {
            (window as any).showToast?.(data?.error || 'Save failed', 'error');
          } else {
            (window as any).showToast?.('Saved. Deploy queued.');
          }
        } catch {
          (window as any).showToast?.('Network error', 'error');
        } finally {
          if (btn) btn.disabled = false;
        }
      });
    }
  </script>
</Admin>
