---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Thank You"
  description="Your submission has been received."
>
  <Header />

  <main class="flex min-h-[60vh] items-center justify-center px-6">
    <div class="text-center">
      <div class="mx-auto flex size-12 items-center justify-center rounded-full bg-emerald-100">
        <svg class="size-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
      </div>
      <h1 class="mt-4 text-3xl font-semibold tracking-tight">Thank you!</h1>
      <p class="mt-2 text-neutral-500">Your submission has been received. We'll be in touch if needed.</p>
      <a href="/" class="mt-6 inline-flex rounded-md bg-emerald-600 px-3 py-2 text-sm font-medium text-white hover:bg-emerald-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600">
        Back to directory
      </a>
    </div>
  </main>

  <Footer />
</Base>
