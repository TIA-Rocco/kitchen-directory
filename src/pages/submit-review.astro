---
import Base from '../layouts/Base.astro';
import { supabase } from '../lib/supabase';

const { data: serviceCategories } = await supabase
  .from('service_categories')
  .select('name')
  .order('name');
const services = (serviceCategories || []).map((s) => s.name);

const { data: companiesData } = await supabase
  .from('companies')
  .select('id, name')
  .order('ranking_score', { ascending: false });
const sampleCompanies = (companiesData || []).map((c) => ({ slug: c.id, name: c.name }));
---

<Base
  title="Submit a Review"
  description="Share your experience with a commercial kitchen equipment supplier. Your review helps other restaurant operators make informed decisions."
>
  <header class="border-b border-neutral-950/5 bg-white">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
      <a href="/" aria-label="Homepage" class="flex items-center gap-2">
        <img src="https://assets.ui.sh/marks/1.svg?color=emerald-600&text=KE&textColor=neutral-900&font=inter" alt="Kitchen Equipment Canada" class="h-8" />
        <span class="text-lg font-semibold tracking-tight">KitchenEquipment.ca</span>
      </a>
      <a href="/contact" class="rounded-md bg-emerald-600 px-3 py-2 text-sm font-medium text-white hover:bg-emerald-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600">Contact Us</a>
    </nav>
  </header>

  <main class="py-16">
    <div class="mx-auto max-w-xl px-6">
      <a href="/" class="text-sm text-neutral-500 hover:text-neutral-700">&larr; Back to directory</a>

      <h1 class="mt-6 text-3xl font-semibold tracking-tight">Submit a Review</h1>
      <p class="mt-2 text-neutral-500">Share your experience with a commercial kitchen equipment supplier. Your review helps others make informed decisions.</p>

      <form action="/api/review" method="POST" class="mt-10 space-y-6">
        <!-- Honeypot -->
        <div class="hidden" aria-hidden="true">
          <label for="website">Website</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <div>
          <label for="company" class="text-sm font-medium text-neutral-900">Company</label>
          <div class="mt-1.5 inline-grid w-full grid-cols-[1fr_--spacing(8)]">
            <select id="company" name="company_id" required class="col-span-full row-start-1 w-full appearance-none rounded-lg py-2.5 pr-8 pl-3 text-sm ring-1 ring-black/10 focus:outline-2 focus:-outline-offset-1 focus:outline-emerald-600">
              <option value="">Select a company</option>
              {sampleCompanies.map((c) => (
                <option value={c.slug}>{c.name}</option>
              ))}
            </select>
            <svg viewBox="0 0 8 5" width="8" height="5" fill="none" class="pointer-events-none col-start-2 row-start-1 place-self-center">
              <path d="M.5.5 4 4 7.5.5" stroke="currentcolor" />
            </svg>
          </div>
        </div>

        <div>
          <label for="reviewer_name" class="text-sm font-medium text-neutral-900">Your Name</label>
          <input type="text" id="reviewer_name" name="reviewer_name" required class="mt-1.5 w-full rounded-lg px-3 py-2.5 text-sm ring-1 ring-black/10 focus:outline-2 focus:-outline-offset-1 focus:outline-emerald-600 max-sm:text-base/6" placeholder="e.g. Marco R." />
        </div>

        <div>
          <label class="text-sm font-medium text-neutral-900">Rating</label>
          <div class="mt-2 flex gap-2">
            {[1, 2, 3, 4, 5].map((star) => (
              <label class="cursor-pointer">
                <input type="radio" name="rating" value={star} required class="peer sr-only" />
                <span class="flex size-10 items-center justify-center rounded-lg text-neutral-300 ring-1 ring-black/5 transition-colors peer-checked:bg-amber-50 peer-checked:text-amber-400 peer-checked:ring-amber-200 hover:text-amber-300">
                  <svg class="size-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                </span>
              </label>
            ))}
          </div>
        </div>

        <div>
          <label for="service_category" class="text-sm font-medium text-neutral-900">Service Used</label>
          <div class="mt-1.5 inline-grid w-full grid-cols-[1fr_--spacing(8)]">
            <select id="service_category" name="service_category" required class="col-span-full row-start-1 w-full appearance-none rounded-lg py-2.5 pr-8 pl-3 text-sm ring-1 ring-black/10 focus:outline-2 focus:-outline-offset-1 focus:outline-emerald-600">
              <option value="">Select a service</option>
              {services.map((s) => (
                <option value={s}>{s}</option>
              ))}
              <option value="other">Other (specify below)</option>
            </select>
            <svg viewBox="0 0 8 5" width="8" height="5" fill="none" class="pointer-events-none col-start-2 row-start-1 place-self-center">
              <path d="M.5.5 4 4 7.5.5" stroke="currentcolor" />
            </svg>
          </div>
        </div>

        <div>
          <label for="custom_service" class="text-sm font-medium text-neutral-900">Other Service <span class="font-normal text-neutral-400">(optional)</span></label>
          <input type="text" id="custom_service" name="custom_service" class="mt-1.5 w-full rounded-lg px-3 py-2.5 text-sm ring-1 ring-black/10 focus:outline-2 focus:-outline-offset-1 focus:outline-emerald-600 max-sm:text-base/6" placeholder="If your service isn't listed above" />
        </div>

        <div>
          <label for="review_text" class="text-sm font-medium text-neutral-900">Your Review</label>
          <textarea id="review_text" name="review_text" required rows="5" class="mt-1.5 w-full rounded-lg px-3 py-2.5 text-sm ring-1 ring-black/10 focus:outline-2 focus:-outline-offset-1 focus:outline-emerald-600 max-sm:text-base/6" placeholder="Describe your experience working with this company..."></textarea>
        </div>

        <button type="submit" class="w-full rounded-md bg-emerald-600 px-3 py-2.5 text-sm font-medium text-white hover:bg-emerald-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600">
          Submit Review
        </button>

        <p class="text-xs text-neutral-400">Your review will be moderated before appearing on the site. Reviews typically appear within 1-2 business days.</p>
      </form>
    </div>
  </main>

  <footer class="border-t border-neutral-950/5 py-10">
    <div class="mx-auto max-w-7xl px-6 text-center text-sm text-neutral-500">
      <p>kitchenequipment.ca. Independent commercial kitchen equipment supplier directory.</p>
    </div>
  </footer>
</Base>
