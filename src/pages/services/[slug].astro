---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import HeroImage from '../../components/HeroImage.astro';
import { buildItemListSchema, buildFAQPageSchema } from '../../lib/schema';
import type { FaqItem } from '../../lib/types';
import { supabase } from '../../lib/supabase';
import { buildReviewMap, averageRating } from '../../lib/reviews';
import { heroSrcset } from '../../lib/heroImage';

export async function getStaticPaths() {
  const { data: services } = await supabase
    .from('service_categories')
    .select('name, slug, description, faq');
  const { data: allCompanies } = await supabase
    .from('companies')
    .select('*')
    .is('deleted_at', null)
    .order('ranking_score', { ascending: false });

  // Approved review stats per company, aggregated once for all category pages
  // (mirrors the homepage logic in index.astro). Without this the Reviews
  // column would render 0 for every supplier regardless of real reviews.
  // Aggregation/rounding lives in lib/reviews.ts — see the note there on why
  // the arithmetic must stay out of .astro frontmatter.
  const { data: reviewStats } = await supabase
    .from('reviews')
    .select('company_id, rating')
    .eq('status', 'approved');

  const reviewMap = buildReviewMap(reviewStats);

  return (services || []).map((service) => {
    const filtered = (allCompanies || []).filter((c) =>
      c.services.includes(service.name)
    );
    return {
      params: { slug: service.slug },
      props: {
        serviceName: service.name,
        description: service.description as string,
        faq: (service.faq || []) as FaqItem[],
        companies: filtered.map((c) => {
          const stat = reviewMap.get(c.id);
          return {
            ...c,
            city: c.address?.city || '',
            review_count: stat?.count || 0,
            avg_rating: averageRating(stat),
          };
        }),
      },
    };
  });
}

const { slug } = Astro.params;
const { serviceName, description, faq, companies } = Astro.props;

// Per-banner vertical crop anchor for the hero photo. Most banners center
// cleanly; a few have the subject sitting low in frame, so we nudge the
// visible window downward (higher %) to raise the subject. Defaults to center.
const HERO_POSITION: Record<string, string> = {
  'commercial-equipment-procurement': 'center 28%',
  'design-and-technical-drawings': 'center 72%',
  'equipment-financing': 'center 75%',
  'price-match': 'center 20%',
};
const heroPosition = HERO_POSITION[slug] ?? 'center';

// ItemList here is CATEGORY-SPECIFIC: only the companies filtered for this
// service, scoped to the category URL. (The global homepage ItemList lives on /.)
const itemListSchema = buildItemListSchema(
  companies,
  `Best ${serviceName} Suppliers in Canada`,
  `https://kitchenequipment.ca/services/${slug}`
);

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: serviceName,
  description: `Find the best ${serviceName.toLowerCase()} suppliers for commercial kitchens in Canada.`,
  areaServed: {
    '@type': 'Country',
    name: 'Canada',
  },
  provider: companies.map((c: any) => ({
    '@type': 'LocalBusiness',
    name: c.name,
    url: `https://kitchenequipment.ca/companies/${c.slug}`,
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://kitchenequipment.ca' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://kitchenequipment.ca/services' },
    { '@type': 'ListItem', position: 3, name: serviceName, item: `https://kitchenequipment.ca/services/${slug}` },
  ],
};

// Per-category FAQPage JSON-LD, reusing the shared builder. Emitted only when
// the category has FAQ content, in addition to ItemList + Service + Breadcrumb.
const faqPageSchema = buildFAQPageSchema(faq);

const jsonLd: Record<string, unknown>[] = [
  itemListSchema,
  serviceSchema,
  breadcrumbSchema,
  ...(faqPageSchema ? [faqPageSchema] : []),
];
---

<Base
  title={`${serviceName} - Commercial Kitchen Equipment Suppliers`}
  description={`Compare top-rated ${serviceName.toLowerCase()} suppliers for commercial kitchens in Canada. Independent rankings and verified reviews.`}
  jsonLd={jsonLd}
  heroPreload={{ srcset: heroSrcset(slug as string, 'services/') }}
>
  <Header />

  <main>
    <section class="relative isolate overflow-hidden bg-neutral-950 py-20">
      <HeroImage
        base={slug as string}
        dir="services/"
        position={heroPosition}
        class="absolute inset-0 -z-10 size-full object-cover"
      />
      <div
        class="absolute inset-0 -z-10 bg-gradient-to-r from-neutral-950 via-neutral-950/75 to-neutral-950/25"
        aria-hidden="true"
      ></div>
      <div class="mx-auto max-w-7xl px-6">
        <nav class="mb-6 flex items-center gap-2 text-sm text-neutral-300" aria-label="Breadcrumb">
          <a href="/" class="hover:text-white">Home</a>
          <span>/</span>
          <a href="/services" class="hover:text-white">Services</a>
          <span>/</span>
          <span class="text-white">{serviceName}</span>
        </nav>
        <h1 class="max-w-[30ch] text-5xl font-semibold tracking-tight text-balance text-white">{serviceName}</h1>
        <p class="mt-6 max-w-[48ch] text-lg text-pretty text-neutral-200">Find and compare trusted suppliers offering {serviceName.toLowerCase()} for commercial kitchens across Canada.</p>
      </div>
    </section>

    {description && (
      <section class="border-b border-neutral-950/5 py-10">
        <div class="mx-auto max-w-7xl px-6">
          <p class="max-w-[72ch] text-pretty text-neutral-600">{description}</p>
        </div>
      </section>
    )}

    <section class="py-16">
      <div class="mx-auto max-w-7xl px-6">
        {companies.length > 0 ? (
          <div class="overflow-hidden rounded-xl ring-1 ring-black/5">
            <table class="w-full text-left">
              <thead>
                <tr class="border-b border-neutral-950/5 bg-neutral-50">
                  <th class="py-3.5 pr-2 pl-4 text-xs font-medium text-neutral-500 sm:pr-3 sm:pl-6">Rank</th>
                  <th class="px-2 py-3.5 text-xs font-medium text-neutral-500 sm:px-3">Supplier</th>
                  <th class="px-3 py-3.5 text-xs font-medium text-neutral-500 max-lg:hidden">Location</th>
                  <th class="px-2 py-3.5 text-xs font-medium text-neutral-500 sm:px-3">Score</th>
                  <th class="px-3 py-3.5 text-xs font-medium text-neutral-500 max-md:hidden">Reviews</th>
                  <th class="py-3.5 pr-6 pl-3 text-xs font-medium text-neutral-500 max-md:hidden">Services</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-neutral-950/5">
                {companies.map((company: any, idx: number) => (
                  <tr class="group transition-colors hover:bg-neutral-50/80">
                    <td class="py-5 pr-2 pl-4 align-top sm:py-6 sm:pr-3 sm:pl-6">
                      <span class:list={[
                        'inline-flex size-8 items-center justify-center rounded-lg text-sm font-semibold tabular-nums',
                        idx === 0 ? 'bg-emerald-600 text-white' : 'bg-neutral-100 text-neutral-600'
                      ]}>
                        {idx + 1}
                      </span>
                    </td>
                    <td class="px-2 py-5 align-top sm:px-3 sm:py-6">
                      <div class="flex items-start gap-3 sm:gap-4">
                        <div class="flex size-12 shrink-0 items-center justify-center overflow-hidden rounded-lg bg-white ring-1 ring-black/5 text-lg font-semibold text-neutral-400">
                          {company.logo_url ? (
                            <img src={company.logo_url} alt={`${company.name} logo`} width="48" height="48" loading="lazy" decoding="async" class="size-full object-contain p-1.5" />
                          ) : (
                            company.name.charAt(0)
                          )}
                        </div>
                        <div class="min-w-0">
                          <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
                            <a href={`/companies/${company.slug}`} class="text-base font-semibold text-neutral-900 group-hover:text-emerald-600">{company.name}</a>
                            {company.is_featured && (
                              <span class="inline-flex shrink-0 items-center rounded-full bg-emerald-50 py-0.5 pr-2 pl-1 text-xs font-medium whitespace-nowrap text-emerald-700">
                                <span class="mr-1 inline-flex size-4 items-center justify-center rounded-full bg-emerald-600 text-[10px] text-white">1</span>
                                Top Rated
                              </span>
                            )}
                          </div>
                          <p class="mt-1 max-w-[56ch] text-sm text-pretty text-neutral-500 max-sm:hidden">{company.description}</p>
                          <div class="mt-3 flex flex-wrap gap-1.5 md:hidden">
                            {company.services.slice(0, 2).map((service: string) => (
                              <span class="rounded-md bg-neutral-100 px-2 py-0.5 text-xs text-neutral-600">{service}</span>
                            ))}
                          </div>
                        </div>
                      </div>
                    </td>
                    <td class="px-3 py-6 align-top max-lg:hidden">
                      <span class="text-sm text-neutral-600">{company.city}</span>
                    </td>
                    <td class="px-2 py-5 align-top sm:px-3 sm:py-6">
                      <div class="flex items-baseline gap-1 whitespace-nowrap">
                        <span class="text-xl font-semibold tabular-nums text-neutral-900 sm:text-2xl">{company.ranking_score}</span>
                        <span class="text-sm text-neutral-400">/10</span>
                      </div>
                    </td>
                    <td class="px-3 py-6 align-top max-md:hidden">
                      <div class="flex items-center gap-1.5">
                        <div class="flex text-amber-400">
                          {Array.from({ length: Math.floor(company.avg_rating) }).map(() => (
                            <svg class="size-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                          ))}
                        </div>
                      </div>
                      <p class="mt-0.5 text-xs text-neutral-400">{company.review_count} reviews</p>
                    </td>
                    <td class="py-6 pr-6 pl-3 align-top max-md:hidden">
                      <div class="flex flex-wrap gap-1.5">
                        {company.services.slice(0, 3).map((service: string) => (
                          <span class="rounded-md bg-neutral-100 px-2 py-0.5 text-xs text-neutral-600">{service}</span>
                        ))}
                        {company.services.length > 3 && (
                          <span class="rounded-md bg-neutral-100 px-2 py-0.5 text-xs text-neutral-400">+{company.services.length - 3}</span>
                        )}
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <div class="rounded-xl bg-neutral-50 p-12 text-center">
            <p class="text-neutral-500">No suppliers currently listed for this service. Check back soon.</p>
            <a href="/" class="mt-4 inline-flex text-sm font-medium text-emerald-600 hover:text-emerald-500">Browse all suppliers</a>
          </div>
        )}
      </div>
    </section>

    {faq.length > 0 && (
      <section class="border-t border-neutral-950/5 py-16">
        <div class="mx-auto max-w-3xl px-6">
          <h2 class="text-2xl font-semibold tracking-tight text-neutral-900">Frequently asked questions</h2>
          <div class="mt-8 divide-y divide-neutral-950/5">
            {faq.map((item: FaqItem) => (
              <details class="faq-item group py-2">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-3 text-base font-medium text-neutral-900 marker:hidden [&::-webkit-details-marker]:hidden">
                  <span>{item.question}</span>
                  <svg class="faq-chevron size-5 shrink-0 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                  </svg>
                </summary>
                <div class="faq-panel">
                  <div class="overflow-hidden">
                    <p class="pb-4 text-sm text-pretty text-neutral-600">{item.answer}</p>
                  </div>
                </div>
              </details>
            ))}
          </div>
          <p class="mt-8 text-sm text-neutral-500">
            Still have questions?
            <a href="/contact" class="font-medium text-emerald-600 hover:text-emerald-500">Contact us</a>.
          </p>
        </div>
      </section>
    )}
  </main>

  <Footer />
</Base>

<style>
  /* Accordion: animate via grid-template-rows (0fr -> 1fr), never height.
     Eased open/close per animation rules; collapses gracefully without JS. */
  .faq-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 280ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .faq-item[open] .faq-panel {
    grid-template-rows: 1fr;
  }
  .faq-chevron {
    transition: transform 280ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .faq-panel,
    .faq-chevron {
      transition: none;
    }
  }
</style>
