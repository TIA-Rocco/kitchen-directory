---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { supabase } from '../../lib/supabase';
import type { BlogPost } from '../../lib/types';
import { buildBlogIndexSchema } from '../../lib/schema';

const { data: postsData } = await supabase
  .from('blog_posts')
  .select('*')
  .eq('status', 'published')
  .order('published_at', { ascending: false });

const posts = (postsData || []) as BlogPost[];

const jsonLd = [buildBlogIndexSchema(posts)];

function formatDate(iso: string | null): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-CA', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Base
  title="Blog — Buying Guides & Industry Insights"
  description="Buying guides, brand comparisons, and industry insights for commercial kitchen equipment buyers across Canada."
  jsonLd={jsonLd}
>
  <Header />

  <main>
    <!-- Breadcrumb -->
    <div class="border-b border-neutral-950/5 bg-neutral-50">
      <div class="mx-auto max-w-7xl px-6 py-3">
        <nav class="flex items-center gap-2 text-sm text-neutral-500" aria-label="Breadcrumb">
          <a href="/" class="hover:text-neutral-700">Home</a>
          <span>/</span>
          <span class="text-neutral-900">Blog</span>
        </nav>
      </div>
    </div>

    <!-- Hero -->
    <section class="bg-neutral-950 py-16">
      <div class="mx-auto max-w-7xl px-6">
        <h1 class="max-w-[28ch] text-5xl font-semibold tracking-tight text-balance text-white">Buying Guides & Industry Insights</h1>
        <p class="mt-6 max-w-[56ch] text-lg text-pretty text-neutral-400">In-depth guides, brand comparisons, and expert tips for restaurant operators sourcing commercial kitchen equipment.</p>
      </div>
    </section>

    <!-- Posts grid -->
    <section class="py-16">
      <div class="mx-auto max-w-7xl px-6">
        {posts.length === 0 ? (
          <div class="rounded-xl border border-dashed border-neutral-300 px-8 py-16 text-center">
            <h2 class="text-lg font-semibold text-neutral-900">No posts yet</h2>
            <p class="mt-2 text-neutral-500">Check back soon — we're working on our first batch of buying guides.</p>
          </div>
        ) : (
          <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
              <li>
                <a href={`/blog/${post.slug}`} class="group flex h-full flex-col overflow-hidden rounded-xl ring-1 ring-black/5 transition-shadow hover:shadow-lg">
                  {post.featured_image_url ? (
                    <div class="aspect-[16/9] overflow-hidden bg-neutral-100">
                      <img
                        src={post.featured_image_url}
                        alt=""
                        loading="lazy"
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                      />
                    </div>
                  ) : (
                    <div class="flex aspect-[16/9] items-center justify-center bg-neutral-100 text-3xl font-semibold text-neutral-300">
                      KE
                    </div>
                  )}
                  <div class="flex flex-1 flex-col gap-3 p-6">
                    {post.category && (
                      <span class="inline-flex w-fit rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-medium text-emerald-700">{post.category}</span>
                    )}
                    <h2 class="text-lg font-semibold tracking-tight text-neutral-900 group-hover:text-emerald-700">{post.title}</h2>
                    {post.excerpt && (
                      <p class="text-sm text-pretty text-neutral-600">{post.excerpt}</p>
                    )}
                    <div class="mt-auto flex items-center gap-2 pt-3 text-xs text-neutral-500">
                      <span>{post.author}</span>
                      <span aria-hidden="true">·</span>
                      <time datetime={post.published_at || post.created_at}>{formatDate(post.published_at)}</time>
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>
  </main>

  <Footer />
</Base>
