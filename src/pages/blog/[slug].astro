---
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
import { supabase } from '../../lib/supabase';
import type { BlogPost, Company } from '../../lib/types';
import { buildBlogPostingSchema } from '../../lib/schema';
import { renderMarkdown } from '../../lib/markdown';

export async function getStaticPaths() {
  const { data: posts } = await supabase
    .from('blog_posts')
    .select('slug')
    .eq('status', 'published');
  return (posts || []).map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;

const { data: postData } = await supabase
  .from('blog_posts')
  .select('*')
  .eq('slug', slug)
  .eq('status', 'published')
  .single();

if (!postData) return Astro.redirect('/404');
const post = postData as BlogPost;

let linkedCompanies: Company[] = [];
if (post.linked_companies && post.linked_companies.length > 0) {
  const { data: companiesData } = await supabase
    .from('companies')
    .select('*')
    .in('id', post.linked_companies)
    .is('deleted_at', null)
    .order('ranking_score', { ascending: false });
  linkedCompanies = (companiesData || []) as Company[];
}

const renderedBody = renderMarkdown(post.body);

const pageTitle = post.meta_title || post.title;
const pageDescription = post.meta_description || post.excerpt || '';

const jsonLd = [buildBlogPostingSchema(post, linkedCompanies)];

function formatDate(iso: string | null): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-CA', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Base
  title={pageTitle}
  description={pageDescription}
  ogImage={post.featured_image_url || undefined}
  jsonLd={jsonLd}
>
  <header class="border-b border-neutral-950/5 bg-white">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
      <a href="/" aria-label="Homepage" class="flex items-center gap-2">
        <img src="https://assets.ui.sh/marks/1.svg?color=emerald-600&text=KE&textColor=neutral-900&font=inter" alt="Kitchen Equipment Canada" class="h-8" />
        <span class="text-lg font-semibold tracking-tight">KitchenEquipment.ca</span>
      </a>
      <div class="flex items-center gap-6">
        <a href="/blog" class="max-sm:hidden text-sm font-medium text-neutral-900">Blog</a>
        <a href="/submit-review" class="max-sm:hidden text-sm font-medium text-neutral-600 hover:text-neutral-900">Submit a Review</a>
        <a href="/list-your-company" class="max-sm:hidden text-sm font-medium text-neutral-600 hover:text-neutral-900">List your company</a>
        <a href="/contact" class="rounded-md bg-emerald-600 px-3 py-2 text-sm font-medium text-white hover:bg-emerald-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600">Contact Us</a>
      </div>
    </nav>
  </header>

  <main>
    <!-- Breadcrumb -->
    <div class="border-b border-neutral-950/5 bg-neutral-50">
      <div class="mx-auto max-w-7xl px-6 py-3">
        <nav class="flex items-center gap-2 text-sm text-neutral-500" aria-label="Breadcrumb">
          <a href="/" class="hover:text-neutral-700">Home</a>
          <span>/</span>
          <a href="/blog" class="hover:text-neutral-700">Blog</a>
          <span>/</span>
          <span class="line-clamp-1 text-neutral-900">{post.title}</span>
        </nav>
      </div>
    </div>

    <!-- Article header -->
    <article class="mx-auto max-w-3xl px-6 pt-12 pb-20">
      <div>
        {post.category && (
          <span class="inline-flex rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-medium text-emerald-700">{post.category}</span>
        )}
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-balance text-neutral-900 sm:text-5xl">{post.title}</h1>
        {post.excerpt && (
          <p class="mt-4 text-lg text-pretty text-neutral-600">{post.excerpt}</p>
        )}
        <div class="mt-6 flex items-center gap-3 text-sm text-neutral-500">
          <span class="font-medium text-neutral-700">{post.author}</span>
          <span aria-hidden="true">·</span>
          <time datetime={post.published_at || post.created_at}>{formatDate(post.published_at)}</time>
        </div>
      </div>

      {post.featured_image_url && (
        <figure class="mt-10 overflow-hidden rounded-xl bg-neutral-100">
          <img src={post.featured_image_url} alt="" class="h-auto w-full object-cover" />
        </figure>
      )}

      <div class="blog-prose mt-10" set:html={renderedBody} />

      {linkedCompanies.length > 0 && (
        <aside class="mt-16 rounded-xl bg-neutral-50 p-6 ring-1 ring-black/5">
          <h2 class="text-lg font-semibold text-neutral-900">Featured Suppliers</h2>
          <p class="mt-1 text-sm text-neutral-500">Suppliers mentioned in this post:</p>
          <ul class="mt-4 space-y-3">
            {linkedCompanies.map((company) => (
              <li>
                <a href={`/companies/${company.slug}`} class="flex items-center gap-4 rounded-lg bg-white p-4 ring-1 ring-black/5 transition-shadow hover:shadow-md">
                  <div class="flex size-12 shrink-0 items-center justify-center overflow-hidden rounded-lg bg-white ring-1 ring-black/5 text-lg font-semibold text-neutral-400">
                    {company.logo_url ? (
                      <img src={company.logo_url} alt={`${company.name} logo`} class="size-full object-contain p-1.5" loading="lazy" />
                    ) : (
                      company.name.charAt(0)
                    )}
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="font-medium text-neutral-900">{company.name}</p>
                    <p class="truncate text-sm text-neutral-500">{company.address?.city}, {company.address?.province} · Score {company.ranking_score}/10</p>
                  </div>
                  <svg class="size-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}
    </article>
  </main>

  <Footer />
</Base>

<style is:global>
  .blog-prose {
    color: var(--color-neutral-700);
    font-size: 1rem;
    line-height: 1.7;
  }
  .blog-prose > * + * {
    margin-top: 1.25em;
  }
  .blog-prose h2 {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-neutral-900);
    margin-top: 2.25em;
    line-height: 1.3;
  }
  .blog-prose h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-neutral-900);
    margin-top: 1.75em;
    line-height: 1.4;
  }
  .blog-prose h4 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-neutral-900);
    margin-top: 1.5em;
  }
  .blog-prose p,
  .blog-prose ul,
  .blog-prose ol,
  .blog-prose blockquote {
    color: var(--color-neutral-700);
  }
  .blog-prose a {
    color: var(--color-emerald-600);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .blog-prose a:hover {
    color: var(--color-emerald-500);
  }
  .blog-prose ul,
  .blog-prose ol {
    padding-left: 1.5em;
  }
  .blog-prose ul {
    list-style: disc;
  }
  .blog-prose ol {
    list-style: decimal;
  }
  .blog-prose li + li {
    margin-top: 0.5em;
  }
  .blog-prose strong {
    color: var(--color-neutral-900);
    font-weight: 600;
  }
  .blog-prose blockquote {
    border-left: 3px solid var(--color-emerald-500);
    padding-left: 1em;
    color: var(--color-neutral-600);
    font-style: italic;
  }
  .blog-prose code {
    background: var(--color-neutral-100);
    padding: 0.15em 0.35em;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }
  .blog-prose pre {
    background: var(--color-neutral-950);
    color: var(--color-neutral-100);
    padding: 1em 1.25em;
    border-radius: 0.5rem;
    overflow-x: auto;
    font-size: 0.9em;
  }
  .blog-prose pre code {
    background: transparent;
    padding: 0;
    color: inherit;
  }
  .blog-prose img {
    border-radius: 0.5rem;
  }
  .blog-prose hr {
    border-color: var(--color-neutral-200);
  }
  .blog-prose table {
    width: 100%;
    border-collapse: collapse;
  }
  .blog-prose th,
  .blog-prose td {
    border-bottom: 1px solid var(--color-neutral-200);
    padding: 0.6em 0.5em;
    text-align: left;
  }
  .blog-prose th {
    color: var(--color-neutral-900);
    font-weight: 600;
  }
</style>
