---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
import { buildWebSiteSchema, buildOrganizationSchema, buildItemListSchema } from '../lib/schema';
import { supabase } from '../lib/supabase';

// Fetch active companies from Supabase, sorted by ranking.
const { data: companiesRaw } = await supabase
  .from('companies')
  .select('*')
  .is('deleted_at', null)
  .order('ranking_score', { ascending: false });

// Fetch review stats per company (approved only) for the condensed list.
const { data: reviewStats } = await supabase
  .from('reviews')
  .select('company_id, rating')
  .eq('status', 'approved');

const reviewMap = new Map<string, { count: number; sum: number }>();
for (const r of reviewStats || []) {
  const existing = reviewMap.get(r.company_id) || { count: 0, sum: 0 };
  existing.count++;
  existing.sum += r.rating;
  reviewMap.set(r.company_id, existing);
}

const rankedCompanies = (companiesRaw || []).map((c) => {
  const stats = reviewMap.get(c.id) || { count: 0, sum: 0 };
  return {
    ...c,
    review_count: stats.count,
    avg_rating: stats.count > 0 ? Math.round((stats.sum / stats.count) * 10) / 10 : 0,
    city: c.address?.city || '',
  };
});

// Condensed "Top Rated Suppliers" list shown on the homepage.
const topSuppliers = rankedCompanies.slice(0, 5);

// Service categories grid (name + condensed card_blurb + slug).
// card_blurb is the short homepage summary; description (long-form AEO copy)
// is the fallback for any category that has not been given a blurb yet.
const { data: serviceCategoriesRaw } = await supabase
  .from('service_categories')
  .select('slug, name, description, card_blurb')
  .order('name');

const serviceCategories = serviceCategoriesRaw || [];

// CRITICAL AEO SIGNAL: the homepage must keep emitting WebSite + Organization
// + ItemList. The ItemList of top suppliers is the primary citation signal and
// stays on / exactly as before. Reuses the schema.ts builders unchanged.
const jsonLd = [
  buildWebSiteSchema(),
  buildOrganizationSchema(),
  buildItemListSchema(
    rankedCompanies,
    'Top Commercial Kitchen Equipment Suppliers in Canada',
    'https://kitchenequipment.ca'
  ),
];
---

<Base
  title="Find Commercial Kitchen Equipment Suppliers in Canada"
  description="Compare top-rated commercial kitchen equipment suppliers across Canada. Independent rankings, verified reviews, and service comparisons."
  jsonLd={jsonLd}
>
  <Header />

  <main>
    <!-- Hero: headline + subcopy over the bright kitchen-team photograph. -->
    <section class="relative isolate overflow-hidden bg-neutral-950">
      <img
        src="/heroes/home.jpg"
        alt=""
        aria-hidden="true"
        fetchpriority="high"
        class="absolute inset-0 -z-10 size-full object-cover object-[center_35%]"
      />
      <!-- Scrim: keeps the white text legible while the right side stays bright and airy. -->
      <div
        class="absolute inset-0 -z-10 bg-gradient-to-r from-neutral-950 via-neutral-950/75 to-neutral-950/25"
        aria-hidden="true"
      ></div>
      <div class="mx-auto max-w-7xl px-6 py-20 lg:py-24">
        <div class="max-w-2xl">
          <h1 class="max-w-[18ch] text-5xl font-semibold tracking-tight text-balance text-white sm:text-6xl">
            Find the Best Commercial Kitchen Equipment Suppliers
          </h1>
          <p class="mt-6 max-w-[48ch] text-lg text-pretty text-neutral-200">
            Independent rankings, verified reviews, and service comparisons for commercial kitchen equipment suppliers across Canada.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="#suppliers"
              class="rounded-md bg-emerald-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-emerald-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600"
            >
              Browse top suppliers
            </a>
            <a
              href="#categories"
              class="rounded-md bg-white/10 px-4 py-2.5 text-sm font-medium text-white ring-1 ring-white/20 backdrop-blur-sm transition-colors hover:bg-white/15 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white/40"
            >
              Explore by service
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Service category grid. -->
    <section id="categories" class="py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-6">
        <div class="max-w-2xl">
          <h2 class="text-2xl font-semibold tracking-tight text-neutral-900 sm:text-3xl">Browse by service</h2>
          <p class="mt-3 text-pretty text-neutral-500">
            Find suppliers by the service you need, from equipment procurement and financing to design and installation.
          </p>
        </div>

        <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {serviceCategories.map((category) => (
            <li>
              <a
                href={`/services/${category.slug}`}
                class="group flex h-full flex-col rounded-2xl border border-neutral-200 bg-white p-6 transition hover:border-emerald-300 hover:shadow-[0_4px_16px_rgba(0,0,0,0.06)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600"
              >
                <span class="flex size-12 items-center justify-center rounded-xl bg-emerald-600 text-white shadow-[0_3px_10px_rgba(0,0,0,0.13)]">
                  <ServiceIcon slug={category.slug} class="size-6" />
                </span>
                <h3 class="mt-4 text-base font-semibold text-neutral-900 group-hover:text-emerald-600">
                  {category.name}
                </h3>
                <p class="mt-1.5 grow text-sm text-pretty text-neutral-500">{category.card_blurb || category.description}</p>
                <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-emerald-600">
                  View suppliers
                  <svg class="size-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Condensed Top Rated Suppliers list. -->
    <section id="suppliers" class="border-t border-neutral-200 bg-neutral-50 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-6">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div class="max-w-2xl">
            <h2 class="text-2xl font-semibold tracking-tight text-neutral-900 sm:text-3xl">Top rated suppliers</h2>
            <p class="mt-3 text-pretty text-neutral-500">
              Our highest ranked commercial kitchen equipment suppliers, scored on service range, reviews, experience, and more.
            </p>
          </div>
        </div>

        <ul class="mt-10 space-y-4">
          {topSuppliers.map((company, idx) => (
            <li>
              <a
                href={`/companies/${company.slug}`}
                class="group flex items-start gap-4 rounded-xl border border-neutral-200 bg-white p-5 transition hover:border-emerald-300 hover:shadow-[0_4px_16px_rgba(0,0,0,0.06)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600 sm:items-center sm:gap-6"
              >
                <span class:list={[
                  'inline-flex size-9 shrink-0 items-center justify-center rounded-lg text-sm font-semibold tabular-nums',
                  idx === 0 ? 'bg-emerald-600 text-white' : 'bg-neutral-100 text-neutral-600',
                ]}>
                  {idx + 1}
                </span>

                <div class="flex size-12 shrink-0 items-center justify-center overflow-hidden rounded-lg bg-white ring-1 ring-black/5 text-lg font-semibold text-neutral-400">
                  {company.logo_url ? (
                    <img src={company.logo_url} alt={`${company.name} logo`} class="size-full object-contain p-1.5" loading="lazy" />
                  ) : (
                    company.name.charAt(0)
                  )}
                </div>

                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
                    <span class="text-base font-semibold text-neutral-900 group-hover:text-emerald-600">{company.name}</span>
                    {company.is_featured && (
                      <span class="inline-flex shrink-0 items-center gap-1 rounded-full bg-emerald-50 py-0.5 pr-2 pl-1 text-xs font-medium whitespace-nowrap text-emerald-700">
                        <span class="inline-flex size-4 shrink-0 items-center justify-center rounded-full bg-emerald-600 text-[10px] text-white">1</span>
                        Top Rated
                      </span>
                    )}
                  </div>
                  {company.city && <p class="mt-0.5 text-sm text-neutral-500">{company.city}</p>}
                  <p class="mt-1 max-w-[64ch] text-sm text-pretty text-neutral-500 max-sm:hidden">{company.description}</p>
                </div>

                <div class="flex shrink-0 flex-col items-end">
                  <div class="flex items-baseline gap-1">
                    <span class="text-2xl font-semibold tabular-nums text-neutral-900">{company.ranking_score}</span>
                    <span class="text-sm text-neutral-400">/10</span>
                  </div>
                  {company.review_count > 0 ? (
                    <p class="mt-0.5 text-xs text-neutral-400">{company.review_count} {company.review_count === 1 ? 'review' : 'reviews'}</p>
                  ) : (
                    <p class="mt-0.5 text-xs text-neutral-400">No reviews yet</p>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>

        <div class="mt-10 flex flex-wrap items-center justify-between gap-4 rounded-2xl bg-neutral-950 px-6 py-6 sm:px-8">
          <div>
            <p class="text-base font-semibold text-white">Run a commercial kitchen equipment company?</p>
            <p class="mt-1 text-sm text-neutral-400">Get listed in the directory and reach operators comparing suppliers across Canada.</p>
          </div>
          <a href="/list-your-company" class="shrink-0 rounded-md bg-emerald-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-emerald-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600">List your company</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
