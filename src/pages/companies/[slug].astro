---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import {
  buildLocalBusinessSchema,
  buildFAQPageSchema,
  buildReviewSchema,
  buildServiceSchema,
} from '../../lib/schema';
import type { Company, Review, RankingBreakdown } from '../../lib/types';
import { RANKING_LABELS, RANKING_WEIGHTS } from '../../lib/types';
import { supabase } from '../../lib/supabase';
import InfoTooltip from '../../components/InfoTooltip.astro';
import GoogleRating from '../../components/GoogleRating.astro';

export async function getStaticPaths() {
  const { data: companies } = await supabase.from('companies').select('slug').is('deleted_at', null);
  return (companies || []).map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;

// Fetch company
const { data: companyData } = await supabase
  .from('companies')
  .select('*')
  .eq('slug', slug)
  .is('deleted_at', null)
  .single();

if (!companyData) return Astro.redirect('/404');
const company = companyData as Company;

// Fetch approved reviews
const { data: reviewsData } = await supabase
  .from('reviews')
  .select('*')
  .eq('company_id', company.id)
  .eq('status', 'approved')
  .order('created_at', { ascending: false });

const reviews = (reviewsData || []) as Review[];
const approvedReviews = reviews;
const avgRating = approvedReviews.length > 0
  ? Math.round((approvedReviews.reduce((sum, r) => sum + r.rating, 0) / approvedReviews.length) * 10) / 10
  : 0;

// Build structured data
const localBusiness = buildLocalBusinessSchema(company, reviews);
const faqPage = buildFAQPageSchema(company.faq);
const reviewSchemas = approvedReviews.map((r) => buildReviewSchema(r, company.name));
const serviceSchemas = company.services.map((s) => buildServiceSchema(s, company.name));

const jsonLd = [
  localBusiness,
  ...(faqPage ? [faqPage] : []),
  ...reviewSchemas,
  ...serviceSchemas,
];
---

<Base
  title={`${company.name} - Commercial Kitchen Equipment`}
  description={company.description}
  jsonLd={jsonLd}
>
  <Header />

  <main>
    <!-- Breadcrumb -->
    <div class="border-b border-neutral-950/5 bg-neutral-50">
      <div class="mx-auto max-w-7xl px-6 py-3">
        <nav class="flex items-center gap-2 text-sm text-neutral-500" aria-label="Breadcrumb">
          <a href="/" class="hover:text-neutral-700">Home</a>
          <span>/</span>
          <a href="/" class="hover:text-neutral-700">Companies</a>
          <span>/</span>
          <span class="text-neutral-900">{company.name}</span>
        </nav>
      </div>
    </div>

    <!-- Company Header -->
    <section class="py-10">
      <div class="mx-auto max-w-7xl px-6">
        <div class="flex flex-col items-start gap-4 sm:flex-row sm:gap-6">
          <div class="flex items-center gap-3">
            <div class="flex size-20 shrink-0 items-center justify-center overflow-hidden rounded-xl bg-white ring-1 ring-black/5 text-3xl font-semibold text-neutral-400">
              {company.logo_url ? (
                <img src={company.logo_url} alt={`${company.name} logo`} width="80" height="80" fetchpriority="high" decoding="async" class="size-full object-contain p-2" />
              ) : (
                company.name.charAt(0)
              )}
            </div>
            {/* Mobile: badge sits beside the logo. Desktop copy lives next to the name below. */}
            {company.is_featured && (
              <span class="rounded-full bg-emerald-50 py-1 pr-2.5 pl-1.5 text-xs font-medium text-emerald-700 sm:hidden">
                <span class="mr-1 inline-flex size-4 items-center justify-center rounded-full bg-emerald-600 text-[10px] text-white">1</span>
                Top Rated
              </span>
            )}
          </div>
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-2">
              <h1 class="text-3xl font-semibold tracking-tight">{company.name}</h1>
              {company.is_featured && (
                <span class="hidden rounded-full bg-emerald-50 py-1 pr-2.5 pl-1.5 text-xs font-medium text-emerald-700 sm:inline-block">
                  <span class="mr-1 inline-flex size-4 items-center justify-center rounded-full bg-emerald-600 text-[10px] text-white">1</span>
                  Top Rated
                </span>
              )}
            </div>
            <p class="mt-1 text-neutral-500">{company.address.city}, {company.address.province}</p>
            <p class="mt-3 max-w-[56ch] text-pretty text-neutral-600">{company.description}</p>
          </div>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-7xl px-6 pb-20">
      <div class="grid gap-10 lg:grid-cols-[1fr_360px]">

        <!-- Main Content -->
        <div class="min-w-0">

          <!-- Ranking Score -->
          <section>
            <h2 class="flex items-center gap-1.5 text-lg font-semibold">
              Rating Breakdown
              <InfoTooltip label="How ratings are calculated">
                <p class="font-medium text-white">How we calculate ratings</p>
                <p class="mt-1 text-neutral-300">
                  Composite score from 6 weighted criteria, editorially assigned by our team:
                </p>
                <ul class="mt-2 space-y-1.5">
                  {(Object.keys(RANKING_LABELS) as (keyof RankingBreakdown)[]).map((key) => (
                    <li class="flex items-baseline justify-between gap-3">
                      <span class="text-neutral-200">{RANKING_LABELS[key]}</span>
                      <span class="shrink-0 tabular-nums text-neutral-400">{Math.round(RANKING_WEIGHTS[key] * 100)}%</span>
                    </li>
                  ))}
                </ul>
              </InfoTooltip>
            </h2>
            <div class="mt-4 flex items-center gap-6">
              <div class="text-center">
                <div class="text-5xl font-semibold tabular-nums text-neutral-900">{company.ranking_score}</div>
                <div class="mt-1 text-sm text-neutral-500">out of 10</div>
              </div>
              <div class="h-16 w-px bg-neutral-200"></div>
              <div class="flex items-center gap-1.5">
                <div class="flex text-amber-400">
                  {Array.from({ length: Math.floor(avgRating) }).map(() => (
                    <svg class="size-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  ))}
                </div>
                <span class="text-lg tabular-nums text-neutral-700">{avgRating}</span>
                <span class="text-sm text-neutral-400">({approvedReviews.length} {approvedReviews.length === 1 ? 'review' : 'reviews'})</span>
              </div>
            </div>

            {/* Attributed third-party Google rating (display-only; never in JSON-LD). Renders nothing without data. */}
            <GoogleRating data={company} />

            <div class="mt-6 space-y-3">
              {(Object.entries(company.ranking_breakdown) as [keyof RankingBreakdown, number][]).map(([key, value]) => (
                <div class="flex items-center gap-4">
                  <span class="w-40 shrink-0 text-sm text-neutral-600">{RANKING_LABELS[key]}</span>
                  <div class="flex-1">
                    <div class="h-2 overflow-hidden rounded-full bg-neutral-100">
                      <div
                        class="h-full rounded-full bg-emerald-500 transition-all"
                        style={`width: ${(value / 10) * 100}%`}
                      ></div>
                    </div>
                  </div>
                  <span class="w-8 text-right text-sm font-medium tabular-nums text-neutral-900">{value}</span>
                </div>
              ))}
            </div>
          </section>

          <!-- Services -->
          <section class="mt-12">
            <h2 class="text-lg font-semibold">Services Offered</h2>
            <div class="mt-4 flex flex-wrap gap-2">
              {company.services.map((service) => (
                <a
                  href={`/services/${service.toLowerCase().replace(/\s+/g, '-').replace(/&/g, 'and')}`}
                  class="rounded-lg bg-neutral-100 px-3 py-1.5 text-sm text-neutral-700 transition-colors hover:bg-emerald-50 hover:text-emerald-700"
                >
                  {service}
                </a>
              ))}
            </div>
          </section>

          <!-- Certifications -->
          {company.certifications && company.certifications.length > 0 && (
            <section class="mt-12">
              <h2 class="text-lg font-semibold">Certifications</h2>
              <p class="mt-1 text-sm text-neutral-500">Credentials and certifications {company.name} holds.</p>
              <ul class="mt-4 flex flex-wrap gap-2">
                {company.certifications.map((cert) => (
                  <li class="inline-flex items-center gap-1.5 rounded-lg bg-emerald-50 px-3 py-1.5 text-sm font-medium text-emerald-700 ring-1 ring-emerald-600/15">
                    <svg class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                    {cert}
                  </li>
                ))}
              </ul>
            </section>
          )}

          <!-- Brand Partners -->
          {company.partners && company.partners.length > 0 && (
            <section class="mt-12">
              <h2 class="text-lg font-semibold">Brand Partners</h2>
              <p class="mt-1 text-sm text-neutral-500">Brands {company.name} carries or has a favourable relationship with.</p>
              <ul class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3">
                {company.partners.map((partner) => {
                  const card = (
                    <div class="flex h-full items-center gap-3 rounded-lg border border-neutral-200 bg-white p-3 transition-colors hover:border-emerald-300 hover:bg-emerald-50/40">
                      {partner.logo_url ? (
                        <img
                          src={partner.logo_url}
                          alt={`${partner.name} logo`}
                          width="96"
                          height="40"
                          loading="lazy"
                          decoding="async"
                          class="h-10 w-24 shrink-0 object-contain"
                        />
                      ) : (
                        <div class="flex h-10 w-24 shrink-0 items-center justify-center rounded bg-neutral-100 text-xs font-semibold text-neutral-500">
                          {partner.name.charAt(0)}
                        </div>
                      )}
                      <span class="min-w-0 truncate text-sm font-medium text-neutral-900">{partner.name}</span>
                    </div>
                  );
                  return (
                    <li>
                      {partner.url ? (
                        <a
                          href={partner.url}
                          target="_blank"
                          rel="noopener nofollow"
                          class="block h-full"
                          aria-label={`Visit ${partner.name} (opens in new tab)`}
                        >
                          {card}
                        </a>
                      ) : (
                        card
                      )}
                    </li>
                  );
                })}
              </ul>
            </section>
          )}

          <!-- Reviews -->
          <section class="mt-12">
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-semibold">Customer Reviews</h2>
              <a href={`/submit-review?company=${company.slug}`} class="text-sm font-medium text-emerald-600 hover:text-emerald-500">Write a Review</a>
            </div>
            <div class="mt-6 space-y-6">
              {approvedReviews.map((review) => (
                <div class="border-t border-neutral-950/5 pt-6 first:border-t-0 first:pt-0">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                      <div class="flex size-9 items-center justify-center rounded-full bg-neutral-100 text-sm font-medium text-neutral-500">
                        {review.reviewer_name.charAt(0)}
                      </div>
                      <div>
                        <p class="text-sm font-medium text-neutral-900">{review.reviewer_name}</p>
                        <p class="text-xs text-neutral-400">{new Date(review.created_at).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                      </div>
                    </div>
                    <div class="flex text-amber-400">
                      {Array.from({ length: review.rating }).map(() => (
                        <svg class="size-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                      ))}
                    </div>
                  </div>
                  <span class="mt-2 inline-block rounded-md bg-neutral-100 px-2 py-0.5 text-xs text-neutral-500">{review.service_category}</span>
                  <p class="mt-2 text-sm text-pretty text-neutral-600">{review.review_text}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="mt-12">
            <h2 class="text-lg font-semibold">Frequently Asked Questions</h2>
            <dl class="mt-6 divide-y divide-neutral-950/5">
              {company.faq.map((item) => (
                <div class="py-5 first:pt-0">
                  <dt class="text-sm font-medium text-neutral-900">{item.question}</dt>
                  <dd class="mt-2 text-sm text-pretty text-neutral-600">{item.answer}</dd>
                </div>
              ))}
            </dl>
          </section>
        </div>

        <!-- Sidebar -->
        <aside class="lg:sticky lg:top-6 lg:self-start">
          <div class="rounded-xl p-6 ring-1 ring-black/5">
            <h3 class="text-sm font-semibold text-neutral-900">Contact Information</h3>
            <dl class="mt-4 space-y-3 text-sm">
              {company.phone && (
                <div>
                  <dt class="text-neutral-500">Phone</dt>
                  <dd class="mt-0.5 font-medium text-neutral-900">{company.phone}</dd>
                </div>
              )}
              {company.email && (
                <div>
                  <dt class="text-neutral-500">Email</dt>
                  <dd class="mt-0.5">
                    <a href={`mailto:${company.email}`} class="font-medium text-emerald-600 hover:text-emerald-500">{company.email}</a>
                  </dd>
                </div>
              )}
              {company.website_url && (
                <div>
                  <dt class="text-neutral-500">Website</dt>
                  <dd class="mt-0.5">
                    <a href={company.website_url} target="_blank" rel="noopener noreferrer" class="font-medium text-emerald-600 hover:text-emerald-500">Visit Website</a>
                  </dd>
                </div>
              )}
              <div>
                <dt class="text-neutral-500">Address</dt>
                <dd class="mt-0.5 text-neutral-900">{company.address.street}<br />{company.address.city}, {company.address.province} {company.address.postal_code}</dd>
              </div>
            </dl>
            <div class="mt-6">
              <a href={`/submit-review?company=${company.slug}`} class="flex w-full items-center justify-center rounded-md bg-emerald-600 px-3 py-2.5 text-sm font-medium text-white hover:bg-emerald-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600">
                Write a Review
              </a>
            </div>
          </div>

          <div class="mt-4 rounded-xl bg-neutral-50 p-6">
            <h3 class="text-sm font-semibold text-neutral-900">Explore More Companies</h3>
            <p class="mt-2 text-sm text-neutral-500">Compare other commercial kitchen equipment suppliers in your area.</p>
            <a href="/" class="mt-4 inline-flex text-sm font-medium text-emerald-600 hover:text-emerald-500">
              View All Suppliers
              <svg class="ml-1 size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <Footer />
</Base>
