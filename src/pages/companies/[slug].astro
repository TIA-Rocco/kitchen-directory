---
import Base from '../../layouts/Base.astro';
import {
  buildLocalBusinessSchema,
  buildFAQPageSchema,
  buildReviewSchema,
  buildServiceSchema,
} from '../../lib/schema';
import type { Company, Review, RankingBreakdown } from '../../lib/types';
import { RANKING_LABELS } from '../../lib/types';

// Static sample data (will be replaced with Supabase queries)
const sampleCompany: Company = {
  id: '1',
  name: 'Shop at Stop Restaurant Supply',
  slug: 'shop-at-stop',
  description: 'Full-service commercial kitchen equipment supplier offering design, financing, procurement, and consulting for restaurants across Ontario. With over 20 years of industry experience, Shop at Stop provides end-to-end solutions for commercial kitchen buildouts, renovations, and equipment upgrades.',
  logo_url: null,
  website_url: 'https://shopatstop.com',
  phone: '(416) 555-0123',
  email: 'info@shopatstop.com',
  address: {
    street: '123 Industry Blvd',
    city: 'Toronto',
    province: 'Ontario',
    postal_code: 'M5V 1A1',
  },
  ranking_score: 9.4,
  ranking_breakdown: {
    service_range: 9.5,
    customer_reviews: 9.6,
    industry_experience: 9.2,
    response_time: 9.0,
    pricing_transparency: 9.5,
    certifications: 9.8,
  },
  services: [
    'Design & Technical Drawings',
    'Equipment Financing',
    'Equipment Leasing',
    'Commercial Equipment Procurement',
    'Price Match',
    'Account Management',
    'Equipment Consulting',
    'Restaurant Consulting',
  ],
  faq: [
    {
      question: 'What areas does Shop at Stop serve?',
      answer: 'Shop at Stop serves the Greater Toronto Area and all of Ontario, with delivery and installation services available throughout the province.',
    },
    {
      question: 'Does Shop at Stop offer equipment financing?',
      answer: 'Yes, Shop at Stop provides flexible equipment financing and leasing options tailored to restaurant operators, helping spread costs over manageable monthly payments.',
    },
    {
      question: 'Can Shop at Stop help with kitchen design?',
      answer: 'Shop at Stop offers complete design and technical drawing services for commercial kitchens, from initial concept to detailed equipment layouts optimized for workflow efficiency.',
    },
    {
      question: 'What brands does Shop at Stop carry?',
      answer: 'Shop at Stop partners with leading commercial kitchen equipment manufacturers, offering a wide selection of brands across cooking, refrigeration, preparation, and storage categories.',
    },
    {
      question: 'Does Shop at Stop offer price matching?',
      answer: 'Yes, Shop at Stop offers a price match guarantee on commercial kitchen equipment, ensuring competitive pricing across all product categories.',
    },
    {
      question: 'How quickly can Shop at Stop deliver equipment?',
      answer: 'Standard delivery within the GTA is typically 3-5 business days. Rush delivery and installation services are available for urgent restaurant openings and renovations.',
    },
  ],
  is_featured: true,
  created_at: '2024-01-15T00:00:00Z',
  updated_at: '2026-04-01T00:00:00Z',
};

const sampleReviews: Review[] = [
  {
    id: '1',
    company_id: '1',
    reviewer_name: 'Marco R.',
    rating: 5,
    service_category: 'Commercial Equipment Procurement',
    custom_service: null,
    review_text: 'Outstanding service from start to finish. They helped us outfit our entire new restaurant kitchen within our budget and timeline. The equipment quality has been excellent.',
    status: 'approved',
    created_at: '2026-03-15T00:00:00Z',
  },
  {
    id: '2',
    company_id: '1',
    reviewer_name: 'Sarah L.',
    rating: 5,
    service_category: 'Design & Technical Drawings',
    custom_service: null,
    review_text: 'Their design team transformed our cramped kitchen layout into an efficient workspace. The technical drawings were detailed and the contractors loved working from them.',
    status: 'approved',
    created_at: '2026-02-20T00:00:00Z',
  },
  {
    id: '3',
    company_id: '1',
    reviewer_name: 'James K.',
    rating: 4,
    service_category: 'Equipment Financing',
    custom_service: null,
    review_text: 'Good financing terms that made our expansion possible. The approval process was straightforward. Would have appreciated slightly faster turnaround on the paperwork.',
    status: 'approved',
    created_at: '2026-01-10T00:00:00Z',
  },
  {
    id: '4',
    company_id: '1',
    reviewer_name: 'Priya M.',
    rating: 5,
    service_category: 'Restaurant Consulting',
    custom_service: null,
    review_text: 'Their consulting team helped us plan our second location from scratch. They understood our brand and workflow needs perfectly. Could not recommend them more highly.',
    status: 'approved',
    created_at: '2025-12-05T00:00:00Z',
  },
];

// Use sample data for now
const company = sampleCompany;
const reviews = sampleReviews;
const approvedReviews = reviews.filter((r) => r.status === 'approved');
const avgRating = approvedReviews.length > 0
  ? Math.round((approvedReviews.reduce((sum, r) => sum + r.rating, 0) / approvedReviews.length) * 10) / 10
  : 0;

// Build structured data
const localBusiness = buildLocalBusinessSchema(company, reviews);
const faqPage = buildFAQPageSchema(company.faq);
const reviewSchemas = approvedReviews.map((r) => buildReviewSchema(r, company.name));
const serviceSchemas = company.services.map((s) => buildServiceSchema(s, company.name));

const jsonLd = [
  localBusiness,
  ...(faqPage ? [faqPage] : []),
  ...reviewSchemas,
  ...serviceSchemas,
];

export function getStaticPaths() {
  return [{ params: { slug: 'shop-at-stop' } }];
}
---

<Base
  title={`${company.name} - Commercial Kitchen Equipment`}
  description={company.description}
  jsonLd={jsonLd}
>
  <header class="border-b border-neutral-950/5 bg-white">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
      <a href="/" aria-label="Homepage" class="flex items-center gap-2">
        <img src="https://assets.ui.sh/marks/1.svg?color=emerald-600&text=KE&textColor=neutral-900&font=inter" alt="Kitchen Equipment Canada" class="h-8" />
        <span class="text-lg font-semibold tracking-tight">KitchenEquipment.ca</span>
      </a>
      <div class="flex items-center gap-6">
        <a href="/submit-review" class="text-sm font-medium text-neutral-600 hover:text-neutral-900">Submit a Review</a>
        <a href="/contact" class="rounded-md bg-emerald-600 px-3 py-2 text-sm font-medium text-white hover:bg-emerald-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600">Contact Us</a>
      </div>
    </nav>
  </header>

  <main>
    <!-- Breadcrumb -->
    <div class="border-b border-neutral-950/5 bg-neutral-50">
      <div class="mx-auto max-w-7xl px-6 py-3">
        <nav class="flex items-center gap-2 text-sm text-neutral-500" aria-label="Breadcrumb">
          <a href="/" class="hover:text-neutral-700">Home</a>
          <span>/</span>
          <a href="/" class="hover:text-neutral-700">Companies</a>
          <span>/</span>
          <span class="text-neutral-900">{company.name}</span>
        </nav>
      </div>
    </div>

    <!-- Company Header -->
    <section class="py-10">
      <div class="mx-auto max-w-7xl px-6">
        <div class="flex items-start gap-6">
          <div class="flex size-20 shrink-0 items-center justify-center rounded-xl bg-neutral-100 text-3xl font-semibold text-neutral-400">
            {company.name.charAt(0)}
          </div>
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-3">
              <h1 class="text-3xl font-semibold tracking-tight">{company.name}</h1>
              {company.is_featured && (
                <span class="rounded-full bg-emerald-50 py-1 pr-2.5 pl-1.5 text-xs font-medium text-emerald-700">
                  <span class="mr-1 inline-flex size-4 items-center justify-center rounded-full bg-emerald-600 text-[10px] text-white">1</span>
                  Top Rated
                </span>
              )}
            </div>
            <p class="mt-1 text-neutral-500">{company.address.city}, {company.address.province}</p>
            <p class="mt-3 max-w-[56ch] text-pretty text-neutral-600">{company.description}</p>
          </div>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-7xl px-6 pb-20">
      <div class="grid gap-10 lg:grid-cols-[1fr_360px]">

        <!-- Main Content -->
        <div class="min-w-0">

          <!-- Ranking Score -->
          <section>
            <h2 class="text-lg font-semibold">Rating Breakdown</h2>
            <div class="mt-4 flex items-center gap-6">
              <div class="text-center">
                <div class="text-5xl font-semibold tabular-nums text-neutral-900">{company.ranking_score}</div>
                <div class="mt-1 text-sm text-neutral-500">out of 10</div>
              </div>
              <div class="h-16 w-px bg-neutral-200"></div>
              <div class="flex items-center gap-1.5">
                <div class="flex text-amber-400">
                  {Array.from({ length: Math.floor(avgRating) }).map(() => (
                    <svg class="size-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  ))}
                </div>
                <span class="text-lg tabular-nums text-neutral-700">{avgRating}</span>
                <span class="text-sm text-neutral-400">({approvedReviews.length} reviews)</span>
              </div>
            </div>

            <div class="mt-6 space-y-3">
              {(Object.entries(company.ranking_breakdown) as [keyof RankingBreakdown, number][]).map(([key, value]) => (
                <div class="flex items-center gap-4">
                  <span class="w-40 shrink-0 text-sm text-neutral-600">{RANKING_LABELS[key]}</span>
                  <div class="flex-1">
                    <div class="h-2 overflow-hidden rounded-full bg-neutral-100">
                      <div
                        class="h-full rounded-full bg-emerald-500 transition-all"
                        style={`width: ${(value / 10) * 100}%`}
                      ></div>
                    </div>
                  </div>
                  <span class="w-8 text-right text-sm font-medium tabular-nums text-neutral-900">{value}</span>
                </div>
              ))}
            </div>
          </section>

          <!-- Services -->
          <section class="mt-12">
            <h2 class="text-lg font-semibold">Services Offered</h2>
            <div class="mt-4 flex flex-wrap gap-2">
              {company.services.map((service) => (
                <a
                  href={`/services/${service.toLowerCase().replace(/\s+/g, '-').replace(/&/g, 'and')}`}
                  class="rounded-lg bg-neutral-100 px-3 py-1.5 text-sm text-neutral-700 transition-colors hover:bg-emerald-50 hover:text-emerald-700"
                >
                  {service}
                </a>
              ))}
            </div>
          </section>

          <!-- Reviews -->
          <section class="mt-12">
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-semibold">Customer Reviews</h2>
              <a href="/submit-review" class="text-sm font-medium text-emerald-600 hover:text-emerald-500">Write a Review</a>
            </div>
            <div class="mt-6 space-y-6">
              {approvedReviews.map((review) => (
                <div class="border-t border-neutral-950/5 pt-6 first:border-t-0 first:pt-0">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                      <div class="flex size-9 items-center justify-center rounded-full bg-neutral-100 text-sm font-medium text-neutral-500">
                        {review.reviewer_name.charAt(0)}
                      </div>
                      <div>
                        <p class="text-sm font-medium text-neutral-900">{review.reviewer_name}</p>
                        <p class="text-xs text-neutral-400">{new Date(review.created_at).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                      </div>
                    </div>
                    <div class="flex text-amber-400">
                      {Array.from({ length: review.rating }).map(() => (
                        <svg class="size-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                      ))}
                    </div>
                  </div>
                  <span class="mt-2 inline-block rounded-md bg-neutral-100 px-2 py-0.5 text-xs text-neutral-500">{review.service_category}</span>
                  <p class="mt-2 text-sm text-pretty text-neutral-600">{review.review_text}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="mt-12">
            <h2 class="text-lg font-semibold">Frequently Asked Questions</h2>
            <dl class="mt-6 divide-y divide-neutral-950/5">
              {company.faq.map((item) => (
                <div class="py-5 first:pt-0">
                  <dt class="text-sm font-medium text-neutral-900">{item.question}</dt>
                  <dd class="mt-2 text-sm text-pretty text-neutral-600">{item.answer}</dd>
                </div>
              ))}
            </dl>
          </section>
        </div>

        <!-- Sidebar -->
        <aside class="lg:sticky lg:top-6 lg:self-start">
          <div class="rounded-xl p-6 ring-1 ring-black/5">
            <h3 class="text-sm font-semibold text-neutral-900">Contact Information</h3>
            <dl class="mt-4 space-y-3 text-sm">
              {company.phone && (
                <div>
                  <dt class="text-neutral-500">Phone</dt>
                  <dd class="mt-0.5 font-medium text-neutral-900">{company.phone}</dd>
                </div>
              )}
              {company.email && (
                <div>
                  <dt class="text-neutral-500">Email</dt>
                  <dd class="mt-0.5">
                    <a href={`mailto:${company.email}`} class="font-medium text-emerald-600 hover:text-emerald-500">{company.email}</a>
                  </dd>
                </div>
              )}
              {company.website_url && (
                <div>
                  <dt class="text-neutral-500">Website</dt>
                  <dd class="mt-0.5">
                    <a href={company.website_url} target="_blank" rel="noopener noreferrer" class="font-medium text-emerald-600 hover:text-emerald-500">Visit Website</a>
                  </dd>
                </div>
              )}
              <div>
                <dt class="text-neutral-500">Address</dt>
                <dd class="mt-0.5 text-neutral-900">{company.address.street}<br />{company.address.city}, {company.address.province} {company.address.postal_code}</dd>
              </div>
            </dl>
            <div class="mt-6">
              <a href="/submit-review" class="flex w-full items-center justify-center rounded-md bg-emerald-600 px-3 py-2.5 text-sm font-medium text-white hover:bg-emerald-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600">
                Write a Review
              </a>
            </div>
          </div>

          <div class="mt-4 rounded-xl bg-neutral-50 p-6">
            <h3 class="text-sm font-semibold text-neutral-900">Explore More Companies</h3>
            <p class="mt-2 text-sm text-neutral-500">Compare other commercial kitchen equipment suppliers in your area.</p>
            <a href="/" class="mt-4 inline-flex text-sm font-medium text-emerald-600 hover:text-emerald-500">
              View All Suppliers
              <svg class="ml-1 size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <footer class="border-t border-neutral-950/5 py-10">
    <div class="mx-auto max-w-7xl px-6 text-center text-sm text-neutral-500">
      <p>kitchenequipment.ca. Independent commercial kitchen equipment supplier directory.</p>
      <div class="mt-3 flex justify-center gap-6">
        <a href="/privacy" class="font-normal hover:text-neutral-700">Privacy Policy</a>
        <a href="/terms" class="font-normal hover:text-neutral-700">Terms of Service</a>
        <a href="/contact" class="font-normal hover:text-neutral-700">Contact</a>
      </div>
    </div>
  </footer>
</Base>
