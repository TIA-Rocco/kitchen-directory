---
// Full-bleed hero photo as a responsive <picture> (AVIF -> WebP -> JPG fallback).
// Replaces the raw <img src="/heroes/...jpg">: same absolute, object-cover layout,
// but the browser now fetches a ~20-40 KB AVIF on mobile instead of a ~350 KB JPG —
// the single biggest lever on mobile LCP / PageSpeed for the homepage + service pages.
//
// Variants are pre-generated by scripts/optimize-images.cjs into the matching opt/
// folder; heroImage.ts builds the srcset/fallback URLs (and the preload in Base.astro).
import { heroSrcset, heroFallback, HERO_WIDTH, HERO_HEIGHT } from '../lib/heroImage';

interface Props {
  /** Base filename without extension, e.g. 'home' or the service slug. */
  base: string;
  /** '' for the homepage hero, 'services/' for service-category banners. */
  dir?: string;
  /** CSS object-position, e.g. 'center 35%'. */
  position?: string;
  /** Classes applied to the <img> (the picture wrapper stays layout-neutral). */
  class?: string;
}

const { base, dir = '', position = 'center', class: className = '' } = Astro.props;
const avif = heroSrcset(base, dir, 'avif');
const webp = heroSrcset(base, dir, 'webp');
const fallback = heroFallback(base, dir);
---

<picture>
  <source type="image/avif" srcset={avif} sizes="100vw" />
  <source type="image/webp" srcset={webp} sizes="100vw" />
  <img
    src={fallback}
    alt=""
    aria-hidden="true"
    width={HERO_WIDTH}
    height={HERO_HEIGHT}
    fetchpriority="high"
    decoding="async"
    class={className}
    style={`object-position: ${position};`}
  />
</picture>
