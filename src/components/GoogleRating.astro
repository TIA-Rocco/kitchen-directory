---
// Attributed third-party Google rating badge — company profile pages only.
//
// DISPLAY-ONLY. This is shown as Google-attributed third-party data and is
// deliberately NOT emitted as the page's own AggregateRating/Review JSON-LD
// (that would risk a deceptive-markup manual action). The page's own structured
// rating stays first-party via src/lib/schema.ts. Renders nothing when there is
// no Google rating, so the editorial /10 score is never left looking blank.
import {
  hasGoogleRating,
  googleStarFillPercent,
  googleAriaLabel,
  formatGoogleReviewCount,
  formatGoogleAsOf,
  googlePlaceHref,
  type GoogleRatingFields,
} from '../lib/googleRating';

interface Props {
  data: GoogleRatingFields;
}

const { data } = Astro.props;
const show = hasGoogleRating(data);

const rating = data.google_rating ?? 0;
const fill = googleStarFillPercent(rating);
const ariaLabel = googleAriaLabel(rating);
const countLabel = formatGoogleReviewCount(data.google_review_count);
const asOf = formatGoogleAsOf(data.google_rating_as_of);
const href = googlePlaceHref(data);

const star =
  'M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z';
---

{show && (
  <div class="mt-6 rounded-xl border border-neutral-200 bg-neutral-50/60 p-4">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
      <div class="flex items-center gap-3">
        <!-- Official Google "G" mark satisfies the Places attribution requirement -->
        <svg viewBox="0 0 24 24" class="size-5 shrink-0" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
        </svg>
        <span class="text-2xl font-semibold tabular-nums text-neutral-900">{rating}</span>
        <span class="relative inline-flex" role="img" aria-label={ariaLabel}>
          <!-- track -->
          <span class="flex text-neutral-300" aria-hidden="true">
            {Array.from({ length: 5 }).map(() => (
              <svg class="size-4" fill="currentColor" viewBox="0 0 20 20"><path d={star} /></svg>
            ))}
          </span>
          <!-- fractional fill -->
          <span class="absolute inset-0 flex overflow-hidden text-amber-400" style={`width:${fill}%`} aria-hidden="true">
            {Array.from({ length: 5 }).map(() => (
              <svg class="size-4 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d={star} /></svg>
            ))}
          </span>
        </span>
      </div>

      <div class="flex flex-wrap items-center gap-x-2 text-sm text-neutral-500">
        <span class="font-medium text-neutral-700">Google rating</span>
        <span aria-hidden="true">·</span>
        <span>{countLabel}</span>
        {asOf && (
          <>
            <span aria-hidden="true">·</span>
            <span class="text-neutral-400">as of {asOf}</span>
          </>
        )}
      </div>

      {href && (
        <a
          href={href}
          target="_blank"
          rel="noopener nofollow"
          class="ml-auto inline-flex items-center gap-1 text-sm font-medium text-emerald-600 hover:text-emerald-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600"
          aria-label="View this company's reviews on Google (opens in new tab)"
        >
          View on Google
          <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      )}
    </div>
  </div>
)}
